                                                    Classes="panel"
                                                    Width="154"
                                                    Height="124"
                                                    IsVisible="{Binding !IsInternetChannelListButtonVisible}" />
                                            <Border Grid.Row="1" Classes="buttonFrame" Width="154" Height="124" PointerPressed="OnAmFmChannelSetPressed">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CH&#x0a;SET" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Classes="panel"
                                Width="916"
                                Height="637"
                                IsVisible="{Binding IsCadContentVisible}"
