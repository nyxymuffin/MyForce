                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
            </Grid>
        </Viewbox>

        <Border IsVisible="{Binding IsAdminOverlayVisible}"
                Background="#F20B0B0B"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="2"
                Padding="16"
                ZIndex="100">
            <Grid ColumnDefinitions="320,*"
                  ColumnSpacing="16">
                <Border Classes="panel"
                        Grid.Column="0"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*,Auto"
                          RowSpacing="12">
                        <TextBlock Classes="white"
                                   FontSize="26"
                                   Text="ADMIN" />

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10">
                                <Expander Classes="adminMenu" Header="SYSTEM" IsExpanded="True">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminSystemPressed" Padding="10">
                                            <TextBlock Classes="white" Text="General" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="AUDIO">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminAudioPressed" Padding="10">
                                            <TextBlock Classes="white" Text="Routing / Devices" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="RADIO">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminRadioPressed" Padding="10">
                                            <TextBlock Classes="white" Text="Resources / Channels" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="NETWORK">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminNetworkPressed" Padding="10">
                                            <TextBlock Classes="white" Text="MQTT / LAN" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="SECURITY">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminSecurityPressed" Padding="10">
                                            <TextBlock Classes="white" Text="Users / Roles" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="INTEGRATIONS">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminIntegrationsPressed" Padding="10">
                                            <TextBlock Classes="white" Text="CAD / Siren / SCADA" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="DIAGNOSTICS">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminDiagnosticsPressed" Padding="10">
                                            <TextBlock Classes="white" Text="Health / Logs" />
                                        </Border>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2"
                                Classes="buttonFrame"
                                PointerPressed="OnCloseAdminPressed"
                                Padding="12">
                            <TextBlock Classes="white"
                                       FontSize="18"
                                       TextAlignment="Center"
                                       Text="CLOSE ADMIN" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="panel"
                        Padding="20">
                    <Grid RowDefinitions="Auto,Auto,*"
                          RowSpacing="16">
                        <TextBlock Classes="white"
                                   FontSize="30"
                                   Text="{Binding AdminSectionTitle}" />
                        <TextBlock Grid.Row="1"
                                   Classes="white"
                                   FontSize="18"
                                   TextWrapping="Wrap"
                                   Text="{Binding AdminSectionDescription}" />
                        <Border Grid.Row="2"
                                Classes="panel"
                                Padding="20">
                            <TextBlock Classes="white"
                                       FontSize="22"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Text="Configuration editor placeholder. The selected admin category will render here full screen." />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsInternetChannelListVisible}"
                Background="#E6101010"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="2"
                Padding="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="620"
                Width="620"
                ZIndex="90">
            <Grid RowDefinitions="Auto,Auto,*,Auto"
                  RowSpacing="10">
                <TextBlock Classes="white"
                           FontSize="20"
                           Text="INT CHANNEL LIST" />

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*,Auto"
                      ColumnSpacing="8">
                    <Border Grid.Column="0"
                            Classes="buttonFrame"
                            PointerPressed="OnInternetGenreFilterPressed"
                            Padding="8">
                        <TextBlock Classes="white"
                                   Text="{Binding InternetGenreFilter, StringFormat='GENRE: {0}'}" />
                    </Border>
                    <Border Grid.Column="1"
                            Classes="buttonFrame"
                            PointerPressed="OnInternetLanguageFilterPressed"
                            Padding="8">
                        <TextBlock Classes="white"
                                   Text="{Binding InternetLanguageFilter, StringFormat='LANG: {0}'}" />
                    </Border>
                    <Border Grid.Column="2"
                            Classes="buttonFrame"
                            PointerPressed="OnCloseInternetChannelListPressed"
                            Padding="8,8,12,8">
                        <TextBlock Classes="white"
                                   Text="CLOSE" />
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      RowDefinitions="Auto,*,Auto"
                      RowSpacing="8">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                        <Border Classes="buttonFrame"
                                Width="72"
                                Height="52"
                                PointerPressed="OnInternetStationsUpPressed"
                                IsEnabled="{Binding CanScrollInternetStationsUp}">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="▲" />
                            </Viewbox>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Classes="white"
                                   VerticalAlignment="Center"
                                   Text="Touch-friendly paging for Internet radio channels." />
                    </Grid>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding VisibleInternetRadioStations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:InternetRadioStation">
                                <Border Classes="buttonFrame"
                                        Margin="0,0,0,8"
                                        Padding="10"
                                        PointerPressed="OnInternetStationPressed"
                                        Tag="{Binding StreamUrl}">
                                    <Grid ColumnDefinitions="2*,*,Auto"
                                          ColumnSpacing="10">
                                        <TextBlock Classes="white"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding DisplayName}" />
                                        <TextBlock Grid.Column="1"
                                                   Classes="white"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Genre}" />
                                        <TextBlock Grid.Column="2"
                                                   Classes="white"
                                                   Text="{Binding Language}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="2"
                            Classes="buttonFrame"
                            Width="72"
                            Height="52"
                            HorizontalAlignment="Left"
                            PointerPressed="OnInternetStationsDownPressed"
                            IsEnabled="{Binding CanScrollInternetStationsDown}">
                        <Viewbox Stretch="Uniform">
                            <TextBlock Classes="white"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="▼" />
                        </Viewbox>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="3"
                           Classes="white"
                           FontSize="14"
                           Text="Select A Station" />
            </Grid>
        </Border>
    </Grid>
</Window>