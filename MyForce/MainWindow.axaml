                        </Border>

                        <Border Classes="panel"
                                Width="916"
                                Height="637"
                                IsVisible="{Binding IsCameraContentVisible}"
                                Padding="24">
                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="16">
                                <TextBlock Classes="white"
                                           FontSize="32"
                                           Text="CAMERA" />
                                <TextBlock Grid.Row="1"
                                           Classes="white"
                                           FontSize="22"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
