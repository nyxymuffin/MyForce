                                           FontSize="32"
                                           Text="RADIO" />
                                <TextBlock Grid.Row="1"
                                           Classes="white"
                                           FontSize="22"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Text="Radio tab content coming next." />
