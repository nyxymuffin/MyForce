<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="using:MyForce.ViewModels"
        xmlns:models="using:MyForce.Models"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        x:Class="MyForce.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="760"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="#2D090B"
        Title="MyForce">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush" Color="#2D090B" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#6A0D14" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8F8F8" />
        <SolidColorBrush x:Key="SignalBrush" Color="#9BD653" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#808080" />
        <SolidColorBrush x:Key="ActiveButtonBorderBrush" Color="#7DB4F0" />
        <SolidColorBrush x:Key="ActiveButtonBrush" Color="#2B71BB" />
        <SolidColorBrush x:Key="AlertBrush" Color="#96302A" />
        <!-- Active directional flash colors. -->
        <SolidColorBrush x:Key="DirectionalActiveBrush" Color="#F39900" />
        <SolidColorBrush x:Key="DirectionalActiveBorderBrush" Color="#F39900" />
        <!-- Active code button colors. -->
        <SolidColorBrush x:Key="Code1ActiveBrush" Color="#1CFF1C" />
        <SolidColorBrush x:Key="Code1ActiveBorderBrush" Color="#1CFF1C" />
        <SolidColorBrush x:Key="Code2ActiveBrush" Color="#EED202" />
        <SolidColorBrush x:Key="Code2ActiveBorderBrush" Color="#EED202" />
        <SolidColorBrush x:Key="Code3ActiveBrush" Color="#CE2029" />
        <SolidColorBrush x:Key="Code3ActiveBorderBrush" Color="#CE2029" />

        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#191919" Offset="0" />
            <GradientStop Color="#101010" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#3A3A3A" Offset="0" />
            <GradientStop Color="#232323" Offset="0.45" />
            <GradientStop Color="#111111" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>

        <Style Selector="Border.buttonFrame">
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>

        <Style Selector="Border.buttonFrame.active">
            <Setter Property="Background" Value="{StaticResource ActiveButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ActiveButtonBorderBrush}" />
        </Style>

        <!-- Scene-light active state: white button (text is set black inline so it stays readable). -->
        <Style Selector="Border.buttonFrame.sceneActive">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="White" />
        </Style>

        <!-- Flash the active directional selection. -->
        <Style Selector="Border.buttonFrame.directionalActive">
            <Setter Property="Background" Value="{StaticResource DirectionalActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DirectionalActiveBorderBrush}" />
            <Setter Property="Opacity" Value="1" />
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="INFINITE" PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.35" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Apply the active Code 1 color. -->
        <Style Selector="Border.buttonFrame.code1Active">
            <Setter Property="Background" Value="{StaticResource Code1ActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Code1ActiveBorderBrush}" />
        </Style>

        <!-- Apply the active Code 2 color. -->
        <Style Selector="Border.buttonFrame.code2Active">
            <Setter Property="Background" Value="{StaticResource Code2ActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Code2ActiveBorderBrush}" />
        </Style>

        <!-- Apply the active Code 3 color. -->
        <Style Selector="Border.buttonFrame.code3Active">
            <Setter Property="Background" Value="{StaticResource Code3ActiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Code3ActiveBorderBrush}" />
        </Style>

        <Style Selector="TextBlock.white">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="Border.connectionBanner">
            <Setter Property="Background" Value="#B00020" />
            <Setter Property="BorderBrush" Value="#FFB4AB" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="16" />
        </Style>

        <Style Selector="Expander.adminMenu">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="#161616" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
        </Style>
    </Window.Styles>

    <Grid Background="{StaticResource ShellBrush}">
        <Border Classes="connectionBanner"
                IsVisible="{Binding IsMqttConnectionBannerVisible}"
                ZIndex="10">
            <TextBlock Classes="white"
                       FontSize="18"
                       TextAlignment="Center"
                       Text="{Binding MqttConnectionBannerText}" />
        </Border>

        <Viewbox Stretch="Fill">
            <Grid Width="1280"
                  Height="760"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="0"
                  ColumnDefinitions="304,948"
                  ColumnSpacing="10">
            <Grid Grid.Column="0"
                  Width="304"
                  Height="748"
                  RowDefinitions="87,180,116,101,120,88"
                  RowSpacing="10">
                <Border Grid.Row="0" Classes="panel" Width="304" Height="87" Padding="8">
                    <Grid ColumnDefinitions="84,182" ColumnSpacing="12" HorizontalAlignment="Center">
                        <StackPanel Width="84" Height="63" Spacing="0" HorizontalAlignment="Center" PointerPressed="OnSpeedPressed">
                            <TextBlock Classes="white"
                                       Width="84"
                                       Height="24"
                                       FontSize="18"
                                       TextAlignment="Center"
                                       Text="{Binding SpeedLabel}" />
                            <!-- Speed Information -->
                            <TextBlock Width="84"
                                       Height="42"
                                       Foreground="{StaticResource SignalBrush}"
                                       FontFamily="Segoe UI"
                                       FontWeight="Bold"
                                       FontSize="30"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding SpeedValue}" />
                            
                        </StackPanel>

                        <StackPanel Grid.Column="1" Width="182" Height="63" Spacing="0" HorizontalAlignment="Center">
                            <TextBlock Classes="white"
                                       Width="182"
                                       Height="20"
                                       FontSize="16"
                                       TextAlignment="Center"
                                       Text="{Binding LocationLabel}" />
                            <!-- Location Information -->
                            <Viewbox Width="182"
                                     Height="26"
                                     Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <TextBlock Width="182"
                                        Height="26"
                                       Foreground="{StaticResource SignalBrush}"
                                       FontFamily="Segoe UI"
                                       FontWeight="Bold"
                                        FontSize="16"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding LocationValue}" />
                            </Viewbox>
                            <Viewbox Width="182"
                                     Height="20"
                                     Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <TextBlock Classes="white"
                                            FontSize="12"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                            TextWrapping="NoWrap"
                                           Text="{Binding What3WordsDisplay}" />
                            </Viewbox>

                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Classes="panel" Width="304" Height="180" Padding="12">
                    <Grid RowDefinitions="35,29,87" RowSpacing="0">
                        <!-- Current Radio -->
                        <TextBlock Classes="white"
                                   Height="35"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Text="{Binding CurrentTalkRadio, StringFormat='TALK RADIO: {0}'}" />
                        <!-- Current Channel Channel -->
                        <TextBlock Grid.Row="1"
                                   Classes="white"
                                   Height="29"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Text="{Binding CurrentRadioChannel, StringFormat='RADIO CH: {0}'}" />
                        <Grid Grid.Row="2"
                              Width="278"
                              Height="87"
                              ColumnDefinitions="86,86,88"
                              ColumnSpacing="6"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Bottom">
                            <Border Grid.Column="0" Classes="buttonFrame" Width="86" Height="81" PointerPressed="OnChannelUpPressed">
                                <Viewbox Stretch="Uniform">
                                    <!-- Current Channel Channel Up -->
                                    <TextBlock Classes="white"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="CH UP" />
                                </Viewbox>
                            </Border>
                            <Border Grid.Column="1" Classes="buttonFrame" Width="86" Height="81" PointerPressed="OnChannelDownPressed">
                                <Viewbox Stretch="Uniform">
                                    <!-- Current Channel Channel Down -->
                                    <TextBlock Classes="white"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="CH DN" />
                                </Viewbox>
                            </Border>
                            <Border Grid.Column="2" Classes="buttonFrame" Width="88" Height="81" PointerPressed="OnScanPressed">
                                <Viewbox Stretch="Uniform">
                                    <!-- Current Selected Channel Scan Button -->
                                    <TextBlock Classes="white"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="SCAN" />
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Classes="panel" Width="304" Height="126" Padding="12">
                    <StackPanel Width="278" Height="125" Spacing="0">
                        <TextBlock Classes="white"
                                   Height="31"
                                   FontSize="18"
                                   Text="{Binding AlertLightSiren, StringFormat='ALERT L/S :  {0}'}" />
                        <TextBlock Classes="white"
                                   Height="31"
                                   FontSize="18"
                                   Text="{Binding DirectionalStatus, StringFormat='DIRECTIONAL :  {0}'}" />
                        <TextBlock Classes="white"
                                   Height="31"
                                   FontSize="18"
                                   Text="SCENE :  LA / TD / RA" />
                        <Grid Height="31"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="4">
                            <TextBlock Classes="white"
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       Text="{Binding EntertainmentModePrefix}" />
                            <Viewbox Grid.Column="1"
                                     Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     MaxWidth="238"
                                     MaxHeight="31">
                                <TextBlock Classes="white"
                                           Text="{Binding EntertainmentModeName}" />
                            </Viewbox>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3" Classes="panel" Width="304" Height="100" Padding="12,10">
                    <Grid Width="278"
                          Height="78"
                          RowDefinitions="26,26,26"
                          RowSpacing="0"
                          VerticalAlignment="Center">
                        <!-- Radio id received on the current channel -->
                        <TextBlock Classes="white"
                                   Width="278"
                                   Height="26"
                                   FontSize="13"
                                   TextAlignment="Center"
                                   Text="{Binding RxRidDisplay}" />
                        <!-- Physical hand grip controller (HCD) mode -->
                        <TextBlock Grid.Row="1"
                                   Classes="white"
                                   Width="278"
                                   Height="26"
                                   FontSize="13"
                                   TextAlignment="Center"
                                   Text="{Binding HandGripModeDisplay}" />
                        <!-- Active soft-key set (follows the hand grip mode) -->
                        <TextBlock Grid.Row="2"
                                   Classes="white"
                                   Width="278"
                                   Height="26"
                                   FontSize="13"
                                   TextAlignment="Center"
                                   Text="{Binding SoftKeysDisplay}" />
                    </Grid>
                </Border>

                <Border Grid.Row="4" Classes="panel" Width="304" Height="130" Padding="12">
                    <Grid Width="278"
                          Height="99"
                          ColumnDefinitions="86,86,88"
                          ColumnSpacing="6"
                          VerticalAlignment="Bottom">
                        <!-- Camera Start Rec Button. Momentary: flashes the active highlight on
                             press (IsCameraRecordActive) to confirm the GPIO pulse was sent. -->
                        <Border Grid.Column="0" Classes="buttonFrame" Width="86" Height="93" PointerPressed="OnCameraRecordPressed" IsVisible="{Binding !IsCameraRecordActive}">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="REC" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="0" Classes="buttonFrame active" Width="86" Height="93" PointerPressed="OnCameraRecordPressed" IsVisible="{Binding IsCameraRecordActive}">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="REC" />
                            </Viewbox>
                        </Border>
                        <!-- Camera Stop Rec Button -->
                        <Border Grid.Column="1" Classes="buttonFrame" Width="86" Height="93" PointerPressed="OnCameraStopPressed" IsVisible="{Binding !IsCameraStopActive}">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="STOP" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="1" Classes="buttonFrame active" Width="86" Height="93" PointerPressed="OnCameraStopPressed" IsVisible="{Binding IsCameraStopActive}">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="STOP" />
                            </Viewbox>
                        </Border>
                        <!-- Front Camera Auto Zoom -->
                        <Border Grid.Column="2" Classes="buttonFrame" Width="88" Height="93" PointerPressed="OnCameraAutoZoomPressed" IsVisible="{Binding !IsCameraAutoZoomActive}">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="AUTOZ" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="2" Classes="buttonFrame active" Width="88" Height="93" PointerPressed="OnCameraAutoZoomPressed" IsVisible="{Binding IsCameraAutoZoomActive}">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="AUTOZ" />
                            </Viewbox>
                        </Border>
                    </Grid>
                </Border>


                <Border Grid.Row="5" Classes="panel" Width="298" Height="88" Padding="8">
                    <Grid Width="280"
                          Height="70"
                           ColumnDefinitions="132,61,75"
                          ColumnSpacing="6">
                        <!-- Clock and Date -->
                        <StackPanel Width="132" Height="64" Spacing="0">
                            <Viewbox Width="132"
                                     Height="34"
                                     Stretch="Uniform"
                                     StretchDirection="DownOnly"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <TextBlock Classes="white"
                                           FontSize="30"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Text="{Binding Clock}" />
                            </Viewbox>
                            <TextBlock Classes="white"
                                       Width="132"
                                       Height="23"
                                       FontSize="15"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Padding="8,0"
                                       Text="{Binding Date}" />
                        </StackPanel>

                        <!-- Current Channel Volume -->
                        <StackPanel Grid.Column="1" Width="61" Height="64" Spacing="0">
                            <TextBlock Classes="white"
                                       Width="61"
                                       Height="26"
                                       FontSize="20"
                                       TextAlignment="Center"
                                       Text="VOL" />
                            <TextBlock Width="61"
                                       Height="37"
                                       Foreground="{StaticResource SignalBrush}"
                                       FontFamily="Segoe UI"
                                       FontWeight="Bold"
                                       FontSize="28"
                                       TextAlignment="Center"
                                       Text="{Binding CurrentTalkRadioVolume}" />
                        </StackPanel>

                        <Border Grid.Column="2"
                                Width="75"
                                Height="64"
                                Background="{StaticResource AlertBrush}"
                                BorderBrush="{StaticResource ActiveButtonBorderBrush}"
                                BorderThickness="2"
                                CornerRadius="3"
                                 PointerPressed="OnEmergencyPressed">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="E-911" />
                            </Viewbox>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1"
                    Width="948"
                    Height="742"
                    Background="#000000"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="2"
                    CornerRadius="2"
                    Padding="8">
                <Grid Width="930"
                      Height="724"
                      RowDefinitions="66,637"
                      RowSpacing="9">
                    <Grid Width="924"
                          Height="66"
                          ColumnDefinitions="125,125,125,125,125,125,131"
                          ColumnSpacing="6">
                        <Grid Grid.Column="0">
                            <Border Classes="buttonFrame" Width="125" Height="58" VerticalAlignment="Top" PointerPressed="OnPatrolTabPressed" IsVisible="{Binding !IsPatrolTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="PATROL" />
                                </Viewbox>
                            </Border>
                            <Border Classes="buttonFrame active" Width="125" Height="58" VerticalAlignment="Top" PointerPressed="OnPatrolTabPressed" IsVisible="{Binding IsPatrolTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="PATROL" />
                                </Viewbox>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="1">
                            <Border Classes="buttonFrame" Width="125" Height="58" VerticalAlignment="Top" PointerPressed="OnLightsAndSirensTabPressed" IsVisible="{Binding !IsLightsAndSirensTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="L / S" />
                                </Viewbox>
                            </Border>
                            <Border Classes="buttonFrame active" Width="125" Height="58" VerticalAlignment="Top" PointerPressed="OnLightsAndSirensTabPressed" IsVisible="{Binding IsLightsAndSirensTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="L / S" />
                                </Viewbox>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="2">
                            <Border Classes="buttonFrame" Width="125" Height="58" VerticalAlignment="Top" PointerPressed="OnRadioTabPressed" IsVisible="{Binding !IsRadioTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="RADIO" />
                                </Viewbox>
                            </Border>
                            <Border Classes="buttonFrame active" Width="125" Height="58" VerticalAlignment="Top" PointerPressed="OnRadioTabPressed" IsVisible="{Binding IsRadioTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="RADIO" />
                                </Viewbox>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="3">
                            <Border Classes="buttonFrame" Width="125" Height="58" VerticalAlignment="Top" PointerPressed="OnRadarTabPressed" IsVisible="{Binding !IsRadarTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="RADAR" />
                                </Viewbox>
                            </Border>
                            <Border Classes="buttonFrame active" Width="125" Height="58" VerticalAlignment="Top" PointerPressed="OnRadarTabPressed" IsVisible="{Binding IsRadarTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="RADAR" />
                                </Viewbox>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="4">
                            <Border Classes="buttonFrame" Width="125" Height="58" VerticalAlignment="Top" PointerPressed="OnAmFmTabPressed" IsVisible="{Binding !IsAmFmTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="AM/FM" />
                                </Viewbox>
                            </Border>
                            <Border Classes="buttonFrame active" Width="125" Height="58" VerticalAlignment="Top" PointerPressed="OnAmFmTabPressed" IsVisible="{Binding IsAmFmTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="AM/FM" />
                                </Viewbox>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="5">
                            <Border Classes="buttonFrame" Width="125" VerticalAlignment="Top" PointerPressed="OnCadTabPressed" IsVisible="{Binding !IsCadTabSelected}">
                                <Viewbox Width="125" Height="53" Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CAD" />
                                </Viewbox>
                            </Border>
                            <Border Classes="buttonFrame active" Width="125" VerticalAlignment="Top" PointerPressed="OnCadTabPressed" IsVisible="{Binding IsCadTabSelected}">
                                <Viewbox Width="125" Height="53" Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CAD" />
                                </Viewbox>
                            </Border>
                        </Grid>
                        <Grid Grid.Column="6">
                            <Border Classes="buttonFrame" Width="131" Height="58" VerticalAlignment="Top" PointerPressed="OnCameraTabPressed" IsVisible="{Binding !IsCameraTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CAMERA" />
                                </Viewbox>
                            </Border>
                            <Border Classes="buttonFrame active" Width="131" Height="58" VerticalAlignment="Top" PointerPressed="OnCameraTabPressed" IsVisible="{Binding IsCameraTabSelected}">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CAMERA" />
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1"
                          Width="916"
                          Height="637">
                        <Grid Width="916"
                              Height="637"
                              IsVisible="{Binding IsPatrolContentVisible}"
                              ColumnDefinitions="322,578"
                              ColumnSpacing="10">
                        <Border Grid.Column="0" Classes="panel" Width="322" Height="637" Padding="8">
                            <Grid Width="304"
                                  Height="619"
                                  RowDefinitions="223,238,132"
                                  RowSpacing="10">
                                <Border Grid.Row="0" Classes="panel" Width="304" Height="223" Padding="10">
                                    <StackPanel Width="282" Height="204" Spacing="0">
                                        <!-- Radio Current Channel List -->
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="{Binding Radio1ChannelName, StringFormat='RADIO 1: {0}'}" />
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="{Binding Radio2ChannelName, StringFormat='RADIO 2: {0}'}" />
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="{Binding Radio3ChannelName, StringFormat='RADIO 3: {0}'}" />
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="{Binding Radio4ChannelName, StringFormat='RADIO 4: {0}'}" />
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="{Binding Radio5ChannelName, StringFormat='RADIO 5: {0}'}" />
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="{Binding Radio6ChannelName, StringFormat='RADIO 6: {0}'}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Classes="panel" Width="304" Height="238" Padding="10">
                                    <Grid Width="282" Height="216" RowDefinitions="32,184" RowSpacing="0">
                                        <TextBlock Classes="white"
                                                   Width="282"
                                                   Height="32"
                                                   FontSize="18"
                                                   TextAlignment="Center"
                                                   Text="PROXIMITY LIST" />
                                        <Grid Grid.Row="1"
                                              Width="282"
                                              Height="184"
                                              ColumnDefinitions="135,135"
                                              RowDefinitions="86,86"
                                              ColumnSpacing="6"
                                              RowSpacing="6">
                                            <!-- Prox Channel Button 1 -->
                                            <Border Grid.Row="0" Grid.Column="0" Classes="buttonFrame" Width="135" Height="86" PointerPressed="OnProximityChannel1Pressed">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="{Binding ProximityChannel1}" />
                                                </Viewbox>
                                            </Border>
                                            <!-- Prox Channel Button 2 -->
                                            <Border Grid.Row="0" Grid.Column="1" Classes="buttonFrame" Width="135" Height="86" PointerPressed="OnProximityChannel2Pressed">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="{Binding ProximityChannel2}" />
                                                </Viewbox>
                                            </Border>
                                            <!-- Prox Channel Button 3 -->
                                            <Border Grid.Row="1" Grid.Column="0" Classes="buttonFrame" Width="135" Height="86" PointerPressed="OnProximityChannel3Pressed">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="{Binding ProximityChannel3}" />
                                                </Viewbox>
                                            </Border>
                                            <!-- Prox Channel Button 4 -->
                                            <Border Grid.Row="1" Grid.Column="1" Classes="buttonFrame" Width="135" Height="86" PointerPressed="OnProximityChannel4Pressed">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="{Binding ProximityChannel4}" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Classes="panel" Width="298" Height="132" Padding="10">
                                    <Grid Width="276" Height="110" RowDefinitions="32,78">
                                        <TextBlock Classes="white"
                                                   Width="276"
                                                   Height="32"
                                                   FontSize="18"
                                                   TextAlignment="Center"
                                                   Text="{Binding MasterVolumeDisplay}" />
                                        <Grid Grid.Row="1"
                                              Width="276"
                                              Height="78"
                                              ColumnDefinitions="132,132"
                                              ColumnSpacing="6">
                                            <!-- Current Channel Volume Up -->
                                            <Border Grid.Column="0" Classes="buttonFrame" Width="132" Height="72" PointerPressed="OnVolumeUpPressed">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▲" />
                                                </Viewbox>
                                            </Border>
                                            <!-- Current Channel Volume Down -->
                                            <Border Grid.Column="1" Classes="buttonFrame" Width="132" Height="72" PointerPressed="OnVolumeDownPressed">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▼" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1"
                              Width="578"
                              Height="631"
                              RowDefinitions="116,114,375"
                              RowSpacing="10">
                            <Border Grid.Row="0" Classes="panel" Width="578" Height="116" Padding="8">
                                <Grid Width="560"
                                      Height="98"
                                      ColumnDefinitions="180,180,182"
                                      ColumnSpacing="6">
                                    <Grid Grid.Column="0" Width="180" Height="92" RowDefinitions="28,64">
                                        <TextBlock Classes="white" Width="180" Height="28" FontSize="18" TextAlignment="Center" Text="CODE 1" />
                                        <Grid Grid.Row="1">
                                            <Border Classes="buttonFrame" Width="180" Height="64" PointerPressed="OnCode1Pressed" IsVisible="{Binding !IsCode1Selected}">
                                                <Viewbox Stretch="Fill">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="{Binding Code1StateText}" />
                                                </Viewbox>
                                            </Border>
                                            <Border Classes="buttonFrame code1Active" Width="180" Height="64" PointerPressed="OnCode1Pressed" IsVisible="{Binding IsCode1Selected}">
                                                <Viewbox Stretch="Fill">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="{Binding Code1StateText}" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                    <Grid Grid.Column="1" Width="180" Height="92" RowDefinitions="28,64">
                                        <TextBlock Classes="white" Width="180" Height="28" FontSize="18" TextAlignment="Center" Text="CODE 2" />
                                        <Grid Grid.Row="1">
                                            <Border Classes="buttonFrame" Width="180" Height="64" PointerPressed="OnCode2Pressed" IsVisible="{Binding !IsCode2Selected}">
                                                <Viewbox Stretch="Fill">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="{Binding Code2StateText}" />
                                                </Viewbox>
                                            </Border>
                                            <Border Classes="buttonFrame code2Active" Width="180" Height="64" PointerPressed="OnCode2Pressed" IsVisible="{Binding IsCode2Selected}">
                                                <Viewbox Stretch="Fill">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="{Binding Code2StateText}" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                    <Grid Grid.Column="2" Width="182" Height="92" RowDefinitions="28,64">
                                        <TextBlock Classes="white" Width="182" Height="28" FontSize="18" TextAlignment="Center" Text="CODE 3" />
                                        <Grid Grid.Row="1">
                                            <Border Classes="buttonFrame" Width="182" Height="64" PointerPressed="OnCode3Pressed" IsVisible="{Binding !IsCode3Selected}">
                                                <Viewbox Stretch="Fill">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="{Binding Code3StateText}" />
                                                </Viewbox>
                                            </Border>
                                            <Border Classes="buttonFrame code3Active" Width="182" Height="64" PointerPressed="OnCode3Pressed" IsVisible="{Binding IsCode3Selected}">
                                                <Viewbox Stretch="Fill">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="{Binding Code3StateText}" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Classes="panel" Width="578" Height="114" Padding="8">
                                <Grid Width="560" Height="96" RowDefinitions="32,64">
                                    <TextBlock Classes="white"
                                               Width="560"
                                               Height="32"
                                               FontSize="18"
                                               TextAlignment="Center"
                                               Text="DIRECTIONALS" />
                                    <Grid Grid.Row="1"
                                          Width="560"
                                          Height="64"
                                          ColumnDefinitions="180,180,182"
                                          ColumnSpacing="6">
                                        <!-- Directional Left -->
                                        <Grid Grid.Column="0">
                                            <Border Classes="buttonFrame" Width="180" Height="58" PointerPressed="OnDirectionalLeftPressed" IsVisible="{Binding !IsDirectionalLeftSelected}">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="◀" />
                                                </Viewbox>
                                            </Border>
                                            <Border Classes="buttonFrame directionalActive" Width="180" Height="58" PointerPressed="OnDirectionalLeftPressed" IsVisible="{Binding IsDirectionalLeftSelected}">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="◀" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                        <!-- Directional CenterOut -->
                                        <Grid Grid.Column="1">
                                            <Border Classes="buttonFrame" Width="180" Height="58" PointerPressed="OnDirectionalCenterOutPressed" IsVisible="{Binding !IsDirectionalCenterOutSelected}">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="◀ ▶" />
                                                </Viewbox>
                                            </Border>
                                            <Border Classes="buttonFrame directionalActive" Width="180" Height="58" PointerPressed="OnDirectionalCenterOutPressed" IsVisible="{Binding IsDirectionalCenterOutSelected}">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="◀ ▶" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                        <!-- Directional Right -->
                                        <Grid Grid.Column="2">
                                            <Border Classes="buttonFrame" Width="182" Height="58" PointerPressed="OnDirectionalRightPressed" IsVisible="{Binding !IsDirectionalRightSelected}">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▶" />
                                                </Viewbox>
                                            </Border>
                                            <Border Classes="buttonFrame directionalActive" Width="182" Height="58" PointerPressed="OnDirectionalRightPressed" IsVisible="{Binding IsDirectionalRightSelected}">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▶" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2"
                                  Width="572"
                                  Height="375"
                                  ColumnDefinitions="183,183,186"
                                  ColumnSpacing="8">
                                <Grid Grid.Column="0" Width="183" Height="369" RowDefinitions="176,185" RowSpacing="8" VerticalAlignment="Top">
                                    <Border Grid.Row="0" Classes="panel" Width="175" Height="176" Padding="8">
                                        <Grid Width="157" Height="158" RowDefinitions="28,130">
                                            <TextBlock Classes="white"
                                                       Width="157"
                                                       Height="28"
                                                       FontSize="20"
                                                       TextAlignment="Center"
                                                       Text="L / S" />
                                            <Border Grid.Row="1" Classes="buttonFrame" Width="157" Height="130" PointerPressed="OnLightsAndSirensOffPressed">
                                                <Grid>
                                                    <Viewbox Stretch="Uniform"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             MaxWidth="130"
                                                             MaxHeight="104">
                                                        <!-- Lights And Sirens off -->
                                                        <TextBlock Classes="white"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Text="L / S&#x0a;OFF" />
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Siren Radio External Audio -->
                                    <Border Grid.Row="1" Classes="panel" Width="175" Height="185" Padding="8">
                                        <Grid Width="157" Height="167" RowDefinitions="28,139">
                                            <TextBlock Classes="white"
                                                       Width="157"
                                                       Height="28"
                                                       FontSize="13.333"
                                                       TextAlignment="Center"
                                                       Text="EXT AUDIO" />
                                            <Border Grid.Row="1" Classes="buttonFrame" Width="157" Height="139" PointerPressed="OnExternalAudioPressed">
                                                <Grid>
                                                    <Viewbox Stretch="Uniform"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             MaxWidth="120"
                                                             MaxHeight="110">
                                                        <TextBlock Classes="white"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Text="OFF" />
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Voice Memo (soft key 3) with hidden custom soft key 5 below -->
                                <Grid Grid.Column="1" Width="183" Height="369" RowDefinitions="179,182" RowSpacing="8" VerticalAlignment="Top">
                                    <Border Classes="panel" Width="183" Height="179" Padding="8">
                                        <Grid Width="165" Height="161" RowDefinitions="28,133">
                                            <TextBlock Classes="white"
                                                       Width="165"
                                                       Height="28"
                                                       FontSize="18"
                                                       TextAlignment="Center"
                                                       Text="MEMO" />
                                            <Border Grid.Row="1" Classes="buttonFrame" Width="165" Height="133" PointerPressed="OnMemoRecordPressed">
                                                <Grid>
                                                    <Viewbox Stretch="Uniform"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             MaxWidth="120"
                                                             MaxHeight="90">
                                                        <TextBlock Classes="white"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Text="REC" />
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <!-- Hidden custom soft key 5 -->
                                    <Border Grid.Row="1" Classes="panel" Width="183" Height="182" Padding="8" IsVisible="{Binding IsSoftKey5Visible}">
                                        <Grid Width="165" Height="164" RowDefinitions="28,136">
                                            <TextBlock Classes="white"
                                                       Width="165"
                                                       Height="28"
                                                       FontSize="18"
                                                       TextAlignment="Center"
                                                       Text="SOFT 5" />
                                            <Border Grid.Row="1" Classes="buttonFrame" Width="165" Height="136" PointerPressed="OnSoftKey5Pressed">
                                                <Grid>
                                                    <Viewbox Stretch="Uniform"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             MaxWidth="120"
                                                             MaxHeight="90">
                                                        <TextBlock Classes="white"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Text="--" />
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- AM/FM Mute (soft key 4) with hidden custom soft key 6 below -->
                                <Grid Grid.Column="2" Width="186" Height="369" RowDefinitions="176,185" RowSpacing="8" VerticalAlignment="Top">
                                    <Border Classes="panel" Width="186" Height="176" Padding="8">
                                        <Grid Width="168" Height="158" RowDefinitions="28,130">
                                            <TextBlock Classes="white"
                                                       Width="168"
                                                       Height="28"
                                                       FontSize="18"
                                                       TextAlignment="Center"
                                                       Text="AM / FM" />
                                            <Border Grid.Row="1" Classes="buttonFrame" Width="168" Height="130" PointerPressed="OnAmFmMutePressed" IsVisible="{Binding !IsAmFmMuted}">
                                                <Grid>
                                                    <Viewbox Stretch="Uniform"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             MaxWidth="128"
                                                             MaxHeight="92">
                                                        <TextBlock Classes="white"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Text="MUTE" />
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                            <Border Grid.Row="1" Classes="buttonFrame active" Width="168" Height="130" PointerPressed="OnAmFmMutePressed" IsVisible="{Binding IsAmFmMuted}">
                                                <Grid>
                                                    <Viewbox Stretch="Uniform"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             MaxWidth="128"
                                                             MaxHeight="92">
                                                        <TextBlock Classes="white"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Text="MUTE" />
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <!-- Hidden custom soft key 6 -->
                                    <Border Grid.Row="1" Classes="panel" Width="186" Height="185" Padding="8" IsVisible="{Binding IsSoftKey6Visible}">
                                        <Grid Width="168" Height="167" RowDefinitions="28,139">
                                            <TextBlock Classes="white"
                                                       Width="168"
                                                       Height="28"
                                                       FontSize="18"
                                                       TextAlignment="Center"
                                                       Text="SOFT 6" />
                                            <Border Grid.Row="1" Classes="buttonFrame" Width="168" Height="139" PointerPressed="OnSoftKey6Pressed">
                                                <Grid>
                                                    <Viewbox Stretch="Uniform"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             MaxWidth="128"
                                                             MaxHeight="92">
                                                        <TextBlock Classes="white"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Text="--" />
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                        </Grid>

                        <!-- L/S page. Drives the Siren Interface Controller (siren1): CODE 1/2/3
                             and ARROW reuse the patrol bindings; SCENE LIGHTS and AIR HORN drive
                             siren relays via cmd/set. The SIREN box is intentionally left blank. -->
                        <Border Classes="panel"
                                Width="916"
                                Height="637"
                                IsVisible="{Binding IsLightsAndSirensContentVisible}"
                                Padding="24">
                            <Grid Width="868" Height="589" RowDefinitions="468,109" RowSpacing="12">

                                <!-- Top: blank SIREN box | CODE / ARROW / SCENE LIGHTS stack -->
                                <Grid Grid.Row="0" Width="868" Height="468" ColumnDefinitions="338,518" ColumnSpacing="12">

                                    <!-- SIREN box: intentionally blank (no siren controls yet). -->
                                    <Border Grid.Column="0" Classes="panel" Width="338" Height="468" Padding="10">
                                        <TextBlock Classes="white" FontSize="20" TextAlignment="Center" VerticalAlignment="Top" Text="SIREN" />
                                    </Border>

                                    <Grid Grid.Column="1" Width="518" Height="468" RowDefinitions="116,140,188" RowSpacing="12">

                                        <!-- CODE 1 / 2 / 3 (reuses the patrol code state + handlers). -->
                                        <Border Grid.Row="0" Classes="panel" Width="518" Height="116" Padding="8">
                                            <Grid Width="502" Height="100" ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                                <Grid Grid.Column="0" RowDefinitions="28,*">
                                                    <TextBlock Classes="white" FontSize="16" TextAlignment="Center" Text="CODE 1" />
                                                    <Grid Grid.Row="1">
                                                        <Border Classes="buttonFrame" PointerPressed="OnCode1Pressed" IsVisible="{Binding !IsCode1Selected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding Code1StateText}" /></Viewbox>
                                                        </Border>
                                                        <Border Classes="buttonFrame code1Active" PointerPressed="OnCode1Pressed" IsVisible="{Binding IsCode1Selected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding Code1StateText}" /></Viewbox>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                                <Grid Grid.Column="1" RowDefinitions="28,*">
                                                    <TextBlock Classes="white" FontSize="16" TextAlignment="Center" Text="CODE 2" />
                                                    <Grid Grid.Row="1">
                                                        <Border Classes="buttonFrame" PointerPressed="OnCode2Pressed" IsVisible="{Binding !IsCode2Selected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding Code2StateText}" /></Viewbox>
                                                        </Border>
                                                        <Border Classes="buttonFrame code2Active" PointerPressed="OnCode2Pressed" IsVisible="{Binding IsCode2Selected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding Code2StateText}" /></Viewbox>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                                <Grid Grid.Column="2" RowDefinitions="28,*">
                                                    <TextBlock Classes="white" FontSize="16" TextAlignment="Center" Text="CODE 3" />
                                                    <Grid Grid.Row="1">
                                                        <Border Classes="buttonFrame" PointerPressed="OnCode3Pressed" IsVisible="{Binding !IsCode3Selected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding Code3StateText}" /></Viewbox>
                                                        </Border>
                                                        <Border Classes="buttonFrame code3Active" PointerPressed="OnCode3Pressed" IsVisible="{Binding IsCode3Selected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding Code3StateText}" /></Viewbox>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <!-- ARROW / FLASH = directional Left / Center / Right (same as patrol). -->
                                        <Border Grid.Row="1" Classes="panel" Width="518" Height="140" Padding="8">
                                            <Grid Width="502" Height="124" RowDefinitions="28,*" RowSpacing="4">
                                                <TextBlock Classes="white" FontSize="16" TextAlignment="Center" Text="ARROW / FLASH" />
                                                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                                    <Grid Grid.Column="0">
                                                        <Border Classes="buttonFrame" PointerPressed="OnDirectionalLeftPressed" IsVisible="{Binding !IsDirectionalLeftSelected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="◀" /></Viewbox>
                                                        </Border>
                                                        <Border Classes="buttonFrame directionalActive" PointerPressed="OnDirectionalLeftPressed" IsVisible="{Binding IsDirectionalLeftSelected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="◀" /></Viewbox>
                                                        </Border>
                                                    </Grid>
                                                    <Grid Grid.Column="1">
                                                        <Border Classes="buttonFrame" PointerPressed="OnDirectionalCenterOutPressed" IsVisible="{Binding !IsDirectionalCenterOutSelected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="◀ ▶" /></Viewbox>
                                                        </Border>
                                                        <Border Classes="buttonFrame directionalActive" PointerPressed="OnDirectionalCenterOutPressed" IsVisible="{Binding IsDirectionalCenterOutSelected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="◀ ▶" /></Viewbox>
                                                        </Border>
                                                    </Grid>
                                                    <Grid Grid.Column="2">
                                                        <Border Classes="buttonFrame" PointerPressed="OnDirectionalRightPressed" IsVisible="{Binding !IsDirectionalRightSelected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▶" /></Viewbox>
                                                        </Border>
                                                        <Border Classes="buttonFrame directionalActive" PointerPressed="OnDirectionalRightPressed" IsVisible="{Binding IsDirectionalRightSelected}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▶" /></Viewbox>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <!-- SCENE LIGHTS: LEFT ALLEY / TAKE DOWN / RIGHT ALLEY (latching). -->
                                        <Border Grid.Row="2" Classes="panel" Width="518" Height="188" Padding="8">
                                            <Grid Width="502" Height="172" RowDefinitions="28,*" RowSpacing="6">
                                                <TextBlock Classes="white" FontSize="16" TextAlignment="Center" Text="SCENE LIGHTS" />
                                                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                                    <Grid Grid.Column="0">
                                                        <Border Classes="buttonFrame" PointerPressed="OnLeftAlleyPressed" IsVisible="{Binding !IsLeftAlleyActive}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="LEFT ALLEY" /></Viewbox>
                                                        </Border>
                                                        <Border Classes="buttonFrame sceneActive" PointerPressed="OnLeftAlleyPressed" IsVisible="{Binding IsLeftAlleyActive}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" Foreground="Black" TextAlignment="Center" VerticalAlignment="Center" Text="LEFT ALLEY" /></Viewbox>
                                                        </Border>
                                                    </Grid>
                                                    <Grid Grid.Column="1">
                                                        <Border Classes="buttonFrame" PointerPressed="OnTakeDownPressed" IsVisible="{Binding !IsTakeDownActive}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="TAKE DOWN" /></Viewbox>
                                                        </Border>
                                                        <Border Classes="buttonFrame sceneActive" PointerPressed="OnTakeDownPressed" IsVisible="{Binding IsTakeDownActive}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" Foreground="Black" TextAlignment="Center" VerticalAlignment="Center" Text="TAKE DOWN" /></Viewbox>
                                                        </Border>
                                                    </Grid>
                                                    <Grid Grid.Column="2">
                                                        <Border Classes="buttonFrame" PointerPressed="OnRightAlleyPressed" IsVisible="{Binding !IsRightAlleyActive}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="RIGHT ALLEY" /></Viewbox>
                                                        </Border>
                                                        <Border Classes="buttonFrame sceneActive" PointerPressed="OnRightAlleyPressed" IsVisible="{Binding IsRightAlleyActive}">
                                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" Foreground="Black" TextAlignment="Center" VerticalAlignment="Center" Text="RIGHT ALLEY" /></Viewbox>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- Bottom row: AIR HORN only; remaining slots left blank per spec. -->
                                <Grid Grid.Row="1" Width="868" Height="109" ColumnDefinitions="168,168,168,168,*" ColumnSpacing="7">
                                    <Grid Grid.Column="0">
                                        <Border Classes="buttonFrame" PointerPressed="OnAirHornPressed" PointerReleased="OnAirHornReleased" IsVisible="{Binding !IsAirHornActive}">
                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="AIR HORN" /></Viewbox>
                                        </Border>
                                        <Border Classes="buttonFrame active" PointerPressed="OnAirHornPressed" PointerReleased="OnAirHornReleased" IsVisible="{Binding IsAirHornActive}">
                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="AIR HORN" /></Viewbox>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- RADIO page. Selected-radio status + VU meter + TX/RX colouring,
                             channel presets, volume, and the RADIO SELECTION / CHANNEL / CHANNELS
                             / EXT AUDIO / SCAN controls. SELECT opens the radio picker; CHANNELS
                             (replaces MONITOR) opens the channel page. -->
                        <Border Classes="panel" Width="916" Height="637" IsVisible="{Binding IsRadioContentVisible}" Padding="24">
                            <Grid Width="868" Height="589" ColumnDefinitions="430,*" ColumnSpacing="12">

                                <!-- LEFT: radio status, presets, volume -->
                                <Grid Grid.Column="0" Width="430" Height="589" RowDefinitions="210,250,*" RowSpacing="12">

                                    <!-- Radio status + VU meter + TX/RX. TX is red while transmitting,
                                         RX is blue while receiving; the bar is the VU meter. -->
                                    <Border Grid.Row="0" Classes="panel" Width="430" Height="210" Padding="12">
                                        <Grid ColumnDefinitions="*,84">
                                            <StackPanel Grid.Column="0" VerticalAlignment="Top" Spacing="6">
                                                <TextBlock Classes="white" FontSize="20" Text="{Binding RadioPageTitle}" />
                                                <TextBlock Classes="white" FontSize="16" Text="{Binding SelectedRadioChannelLabel}" />
                                                <TextBlock Classes="white" FontSize="16" Text="AREA:" />
                                                <TextBlock Classes="white" FontSize="16" Text="DIV:" />
                                                <TextBlock Classes="white" FontSize="16" Text="{Binding MasterVolumeDisplay}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Spacing="4">
                                                <Border Width="34" Height="150" Background="#202020" BorderBrush="#555555" BorderThickness="1">
                                                    <Rectangle Fill="#33D17A" VerticalAlignment="Bottom" Margin="3" Height="{Binding RadioVuFillHeight}" />
                                                </Border>
                                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                                    <TextBlock Text="TX" FontWeight="Bold" FontSize="16" Foreground="{Binding RadioTxBrush}" />
                                                    <TextBlock Text="RX" FontWeight="Bold" FontSize="16" Foreground="{Binding RadioRxBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- CHANNEL PRESETS -->
                                    <Border Grid.Row="1" Classes="panel" Width="430" Height="250" Padding="10">
                                        <Grid RowDefinitions="28,*" RowSpacing="8">
                                            <TextBlock Classes="white" FontSize="18" TextAlignment="Center" Text="CHANNEL PRESETS" />
                                            <Grid Grid.Row="1" ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="8" RowSpacing="8">
                                                <Border Grid.Row="0" Grid.Column="0" Classes="buttonFrame" PointerPressed="OnRadioPresetPressed" />
                                                <Border Grid.Row="0" Grid.Column="1" Classes="buttonFrame" PointerPressed="OnRadioPresetPressed" />
                                                <Border Grid.Row="1" Grid.Column="0" Classes="buttonFrame" PointerPressed="OnRadioPresetPressed" />
                                                <Border Grid.Row="1" Grid.Column="1" Classes="buttonFrame" PointerPressed="OnRadioPresetPressed" />
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- VOLUME (reuses master output volume) -->
                                    <Border Grid.Row="2" Classes="panel" Width="430" Height="105" Padding="10">
                                        <Grid RowDefinitions="28,*" RowSpacing="6">
                                            <TextBlock Classes="white" FontSize="18" TextAlignment="Center" Text="VOLUME" />
                                            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8">
                                                <Border Grid.Column="0" Classes="buttonFrame" PointerPressed="OnRadioVolumeUpPressed">
                                                    <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▲" /></Viewbox>
                                                </Border>
                                                <Border Grid.Column="1" Classes="buttonFrame" PointerPressed="OnRadioVolumeDownPressed">
                                                    <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▼" /></Viewbox>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- RIGHT: selection / channel / channels / ext audio / scan -->
                                <Grid Grid.Column="1" Width="426" Height="589" RowDefinitions="150,*,110" RowSpacing="12">

                                    <!-- RADIO SELECTION -->
                                    <Border Grid.Row="0" Classes="panel" Width="426" Height="150" Padding="10">
                                        <Grid RowDefinitions="28,*" RowSpacing="8">
                                            <TextBlock Classes="white" FontSize="18" TextAlignment="Center" Text="RADIO SELECTION" />
                                            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                                <Border Grid.Column="0" Classes="buttonFrame" PointerPressed="OnRadioSelectPressed">
                                                    <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="SELECT" /></Viewbox>
                                                </Border>
                                                <Border Grid.Column="1" Classes="buttonFrame" PointerPressed="OnRadioListenPressed">
                                                    <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="LISTEN" /></Viewbox>
                                                </Border>
                                                <Border Grid.Column="2" Classes="buttonFrame" PointerPressed="OnRadioTalkPressed">
                                                    <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="TALK" /></Viewbox>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- CHANNEL up/down | GEO AREA + NUIS | CHANNELS (was MONITOR) -->
                                    <Grid Grid.Row="1" Width="426" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <Border Grid.Column="0" Classes="panel" Padding="8">
                                            <Grid RowDefinitions="24,*,*" RowSpacing="6">
                                                <TextBlock Classes="white" FontSize="15" TextAlignment="Center" Text="CHANNEL" />
                                                <Border Grid.Row="1" Classes="buttonFrame" PointerPressed="OnRadioChannelUpPressed">
                                                    <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▲" /></Viewbox>
                                                </Border>
                                                <Border Grid.Row="2" Classes="buttonFrame" PointerPressed="OnRadioChannelDownPressed">
                                                    <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▼" /></Viewbox>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <Grid Grid.Column="1" RowDefinitions="*,*" RowSpacing="8">
                                            <Border Grid.Row="0" Classes="buttonFrame" PointerPressed="OnRadioGeoAreaPressed">
                                                <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="GEO AREA" /></Viewbox>
                                            </Border>
                                            <Border Grid.Row="1" Classes="buttonFrame" PointerPressed="OnRadioNuisPressed">
                                                <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="NUIS" /></Viewbox>
                                            </Border>
                                        </Grid>
                                        <Border Grid.Column="2" Classes="panel" Padding="8">
                                            <Grid RowDefinitions="24,*" RowSpacing="6">
                                                <TextBlock Classes="white" FontSize="15" TextAlignment="Center" Text="CHANNELS" />
                                                <Border Grid.Row="1" Classes="buttonFrame" PointerPressed="OnRadioChannelsPressed">
                                                    <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="SELECT" /></Viewbox>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <!-- EXT AUDIO + SCAN -->
                                    <Grid Grid.Row="2" Width="426" Height="110" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <Border Grid.Column="0" Classes="buttonFrame" PointerPressed="OnRadioExtAudioPressed">
                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="EXT AUDIO" /></Viewbox>
                                        </Border>
                                        <Border Grid.Column="1" Classes="buttonFrame" PointerPressed="OnRadioScanPressed">
                                            <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="SCAN" /></Viewbox>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Radio-selection overlay (SELECT): pick the radio this console views / keys
                             (§5.4). Rows are the radios programmed in via the admin page. -->
                        <Border Width="916" Height="637" IsVisible="{Binding IsRadioSelectionOverlayVisible}" Background="#CC000000" Padding="40">
                            <Border Classes="panel" Padding="16">
                                <Grid RowDefinitions="40,*,56" RowSpacing="12">
                                    <TextBlock Classes="white" FontSize="24" Text="RADIO SELECTION" />
                                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding RadioSelectionItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Classes="panel" Height="68" Margin="0,0,0,8" Padding="12">
                                                        <Grid ColumnDefinitions="*,150">
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                                                <TextBlock Classes="white" FontSize="18" Text="{Binding Alias}" />
                                                                <TextBlock Classes="white" FontSize="14" Text="{Binding ChannelLabel}" />
                                                            </StackPanel>
                                                            <Border Grid.Column="1" Classes="buttonFrame" PointerPressed="OnRadioSelectionItemPressed">
                                                                <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="SELECT" /></Viewbox>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Border Grid.Row="2" Classes="buttonFrame" Width="160" HorizontalAlignment="Right" PointerPressed="OnRadioSelectionClosePressed">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CLOSE" /></Viewbox>
                                    </Border>
                                </Grid>
                            </Border>
                        </Border>

                        <!-- Channel-selection overlay (CHANNELS, replaces MONITOR). The channel list
                             source is radio-type / plugin specific and is not wired yet. -->
                        <Border Width="916" Height="637" IsVisible="{Binding IsChannelSelectionOverlayVisible}" Background="#CC000000" Padding="40">
                            <Border Classes="panel" Padding="16">
                                <Grid RowDefinitions="40,*,56" RowSpacing="12">
                                    <TextBlock Classes="white" FontSize="24" Text="{Binding ChannelSelectionRadioTitle}" />
                                    <TextBlock Grid.Row="1" Classes="white" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Text="Channel list for this radio is not available yet.&#x0a;It will be populated per radio type / plugin." />
                                    <Border Grid.Row="2" Classes="buttonFrame" Width="160" HorizontalAlignment="Right" PointerPressed="OnChannelSelectionClosePressed">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CLOSE" /></Viewbox>
                                    </Border>
                                </Grid>
                            </Border>
                        </Border>

                        <Border Classes="panel"
                                Width="916"
                                Height="637"
                                IsVisible="{Binding IsRadarContentVisible}"
                                Padding="16">
                            <Grid Width="884"
                                  Height="605"
                                  RowDefinitions="42,553"
                                  RowSpacing="10">
                                <Grid ColumnDefinitions="Auto,*,150"
                                      ColumnSpacing="12"
                                      VerticalAlignment="Center">
                                    <TextBlock Classes="white"
                                               FontSize="28"
                                               VerticalAlignment="Center"
                                               Text="LIVE WEATHER RADAR" />
                                    <TextBlock Grid.Column="1"
                                               Classes="white"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Text="MAP + ACTIVE ALERTS" />
                                    <Border Grid.Column="2"
                                            Classes="buttonFrame"
                                            Width="150"
                                            Height="34"
                                            PointerPressed="OnRadarFollowPressed">
                                        <Viewbox Stretch="Uniform">
                                            <TextBlock Classes="white"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding RadarFollowButtonText}" />
                                        </Viewbox>
                                    </Border>
                                </Grid>
                                <Border Grid.Row="1"
                                        Classes="panel"
                                        Width="884"
                                        Height="553"
                                        Padding="2">
                                    <ContentControl x:Name="RadarMapHost"
                                                    Width="880"
                                                    Height="549"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <Border Classes="panel"
                                Width="916"
                                Height="637"
                                IsVisible="{Binding IsAmFmContentVisible}"
                                Padding="24">
                            <Grid Width="868"
                                  Height="589"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  ColumnDefinitions="358,486"
                                  ColumnSpacing="24">
                                <Grid Width="358"
                                      Height="589"
                                      RowDefinitions="226,224,123"
                                      RowSpacing="16">
                                    <Border Grid.Row="0"
                                            Classes="panel"
                                            Width="358"
                                            Height="226"
                                            Padding="18">
                                        <Grid RowDefinitions="32,92,32"
                                              RowSpacing="14">
                                            <TextBlock Classes="white"
                                                       FontSize="18"
                                                       TextAlignment="Center"
                                                       Text="{Binding AmFmModuleTitle}" />
                                            <TextBlock Grid.Row="1"
                                                       Foreground="{StaticResource SignalBrush}"
                                                       FontFamily="Segoe UI"
                                                       FontWeight="Bold"
                                                        FontSize="{Binding AmFmPrimaryDisplayFontSize}"
                                                        TextAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        TextWrapping="Wrap"
                                                        MaxLines="2"
                                                        Text="{Binding AmFmPrimaryDisplay}" />
                                            <TextBlock Grid.Row="2"
                                                       Classes="white"
                                                       FontSize="18"
                                                       TextAlignment="Center"
                                                       Text="{Binding AmFmDetailLine}" />
                                            <TextBlock Grid.Row="2"
                                                       Margin="0,28,0,0"
                                                       Classes="white"
                                                       FontSize="16"
                                                       TextAlignment="Center"
                                                       IsVisible="{Binding IsAmFmDetailVisible}"
                                                       Text="{Binding AmFmSecondaryDetailLine}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Classes="panel"
                                            Width="358"
                                            Height="224"
                                            Padding="14">
                                        <Grid RowDefinitions="30,1*,1*"
                                              RowSpacing="10">
                                            <TextBlock Classes="white"
                                                       FontSize="18"
                                                       TextAlignment="Center"
                                                       Text="CHANNEL PRESETS" />
                                            <Grid Grid.Row="1"
                                                  ColumnDefinitions="103,103,103"
                                                  ColumnSpacing="10"
                                                  HorizontalAlignment="Center">
                                                <Border Grid.Column="0" Classes="buttonFrame" Width="103" Height="78" PointerPressed="OnAmFmPreset1Pressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding AmFmPreset1Label}" />
                                                    </Viewbox>
                                                </Border>
                                                <Border Grid.Column="1" Classes="buttonFrame" Width="103" Height="78" PointerPressed="OnAmFmPreset2Pressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding AmFmPreset2Label}" />
                                                    </Viewbox>
                                                </Border>
                                                <Border Grid.Column="2" Classes="buttonFrame" Width="103" Height="78" PointerPressed="OnAmFmPreset3Pressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding AmFmPreset3Label}" />
                                                    </Viewbox>
                                                </Border>
                                            </Grid>
                                            <Grid Grid.Row="2"
                                                  ColumnDefinitions="103,103,103"
                                                  ColumnSpacing="10"
                                                  HorizontalAlignment="Center">
                                                <Border Grid.Column="0" Classes="buttonFrame" Width="103" Height="78" PointerPressed="OnAmFmPreset4Pressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding AmFmPreset4Label}" />
                                                    </Viewbox>
                                                </Border>
                                                <Border Grid.Column="1" Classes="buttonFrame" Width="103" Height="78" PointerPressed="OnAmFmPreset5Pressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding AmFmPreset5Label}" />
                                                    </Viewbox>
                                                </Border>
                                                <Border Grid.Column="2" Classes="buttonFrame" Width="103" Height="78" PointerPressed="OnAmFmPreset6Pressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="{Binding AmFmPreset6Label}" />
                                                    </Viewbox>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Classes="panel"
                                            Width="358"
                                            Height="123"
                                            Padding="14">
                                        <Grid RowDefinitions="30,65"
                                              RowSpacing="10">
                                            <TextBlock Classes="white"
                                                       FontSize="18"
                                                       TextAlignment="Center"
                                                       Text="VOLUME" />
                                            <Grid Grid.Row="1"
                                                  ColumnDefinitions="159,159"
                                                  ColumnSpacing="12"
                                                  HorizontalAlignment="Center">
                                                <Border Grid.Column="0" Classes="buttonFrame" Width="159" Height="65" PointerPressed="OnAmFmVolumeUpPressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▲" />
                                                    </Viewbox>
                                                </Border>
                                                <Border Grid.Column="1" Classes="buttonFrame" Width="159" Height="65" PointerPressed="OnAmFmVolumeDownPressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▼" />
                                                    </Viewbox>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Grid Grid.Column="1"
                                      Width="486"
                                      Height="589"
                                      RowDefinitions="176,397"
                                      RowSpacing="16">
                                    <Border Grid.Row="0"
                                            Classes="panel"
                                            Width="486"
                                            Height="176"
                                            Padding="16">
                                        <Grid RowDefinitions="30,110"
                                              RowSpacing="12">
                                            <TextBlock Classes="white"
                                                       FontSize="18"
                                                       TextAlignment="Center"
                                                       Text="AUDIO SOURCE" />
                                            <Grid Grid.Row="1"
                                                  ColumnDefinitions="140,140,140"
                                                  RowDefinitions="49,49"
                                                  ColumnSpacing="17"
                                                  RowSpacing="12"
                                                  HorizontalAlignment="Center">
                                                <Grid Grid.Row="0" Grid.Column="0">
                                                    <Border Classes="buttonFrame" Width="140" Height="49" PointerPressed="OnFm1SourcePressed" IsVisible="{Binding !IsFm1SourceSelected}">
                                                        <Viewbox Stretch="Uniform">
                                                            <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="FM1" />
                                                        </Viewbox>
                                                    </Border>
                                                    <Border Classes="buttonFrame active" Width="140" Height="49" PointerPressed="OnFm1SourcePressed" IsVisible="{Binding IsFm1SourceSelected}">
                                                        <Viewbox Stretch="Uniform">
                                                            <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="FM1" />
                                                        </Viewbox>
                                                    </Border>
                                                </Grid>
                                                <Grid Grid.Row="0" Grid.Column="1">
                                                    <Border Classes="buttonFrame" Width="140" Height="49" PointerPressed="OnAm1SourcePressed" IsVisible="{Binding !IsAm1SourceSelected}">
                                                        <Viewbox Stretch="Uniform">
                                                            <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="AM1" />
                                                        </Viewbox>
                                                    </Border>
                                                    <Border Classes="buttonFrame active" Width="140" Height="49" PointerPressed="OnAm1SourcePressed" IsVisible="{Binding IsAm1SourceSelected}">
                                                        <Viewbox Stretch="Uniform">
                                                            <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="AM1" />
                                                        </Viewbox>
                                                    </Border>
                                                </Grid>
                                                <Grid Grid.Row="1" Grid.Column="0">
                                                    <Border Classes="buttonFrame" Width="140" Height="49" PointerPressed="OnBluetoothSourcePressed" IsVisible="{Binding !IsBluetoothSourceSelected}">
                                                        <Viewbox Stretch="Uniform">
                                                            <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="BT" />
                                                        </Viewbox>
                                                    </Border>
                                                    <Border Classes="buttonFrame active" Width="140" Height="49" PointerPressed="OnBluetoothSourcePressed" IsVisible="{Binding IsBluetoothSourceSelected}">
                                                        <Viewbox Stretch="Uniform">
                                                            <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="BT" />
                                                        </Viewbox>
                                                    </Border>
                                                </Grid>
                                                <Grid Grid.Row="1" Grid.Column="1">
                                                    <Border Classes="buttonFrame" Width="140" Height="49" PointerPressed="OnInternetSourcePressed" IsVisible="{Binding !IsInternetSourceSelected}">
                                                        <Viewbox Stretch="Uniform">
                                                            <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="INT" />
                                                        </Viewbox>
                                                    </Border>
                                                    <Border Classes="buttonFrame active" Width="140" Height="49" PointerPressed="OnInternetSourcePressed" IsVisible="{Binding IsInternetSourceSelected}">
                                                        <Viewbox Stretch="Uniform">
                                                            <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="INT" />
                                                        </Viewbox>
                                                    </Border>
                                                </Grid>
                                                <Grid Grid.Row="0" Grid.RowSpan="2" Grid.Column="2">
                                                    <Border Classes="buttonFrame" Width="140" Height="110" PointerPressed="OnAmFmMutePressed" IsVisible="{Binding !IsAmFmMuted}">
                                                        <Viewbox Stretch="Uniform">
                                                            <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="MUTE" />
                                                        </Viewbox>
                                                    </Border>
                                                    <Border Classes="buttonFrame active" Width="140" Height="110" PointerPressed="OnAmFmMutePressed" IsVisible="{Binding IsAmFmMuted}">
                                                        <Viewbox Stretch="Uniform">
                                                            <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="MUTE" />
                                                        </Viewbox>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1"
                                          Width="486"
                                          Height="397"
                                          ColumnDefinitions="154,154,154"
                                          ColumnSpacing="12">
                                        <Border Grid.Column="0"
                                                Classes="panel"
                                                Width="154"
                                                Height="397"
                                                Padding="12">
                                            <Grid RowDefinitions="30,157,157"
                                                  RowSpacing="14">
                                                <TextBlock Classes="white"
                                                           FontSize="18"
                                                           TextAlignment="Center"
                                                           Text="TUNE" />
                                                <Border Grid.Row="1" Classes="buttonFrame" Width="130" Height="157" HorizontalAlignment="Center" PointerPressed="OnAmFmTuneUpPressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▲" />
                                                    </Viewbox>
                                                </Border>
                                                <Border Grid.Row="2" Classes="buttonFrame" Width="130" Height="157" HorizontalAlignment="Center" PointerPressed="OnAmFmTuneDownPressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▼" />
                                                    </Viewbox>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Classes="panel"
                                                Width="154"
                                                Height="397"
                                                Padding="12"
                                                IsVisible="{Binding IsSeekControlsVisible}">
                                            <Grid RowDefinitions="30,157,157"
                                                  RowSpacing="14">
                                                <TextBlock Classes="white"
                                                           FontSize="18"
                                                           TextAlignment="Center"
                                                           Text="SEEK" />
                                                <Border Grid.Row="1" Classes="buttonFrame" Width="130" Height="157" HorizontalAlignment="Center" PointerPressed="OnAmFmSeekUpPressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▲" />
                                                    </Viewbox>
                                                </Border>
                                                <Border Grid.Row="2" Classes="buttonFrame" Width="130" Height="157" HorizontalAlignment="Center" PointerPressed="OnAmFmSeekDownPressed">
                                                    <Viewbox Stretch="Uniform">
                                                        <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▼" />
                                                    </Viewbox>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Column="1"
                                                Classes="panel"
                                                Width="154"
                                                Height="397"
                                                Padding="12"
                                                IsVisible="{Binding !IsSeekControlsVisible}">
                                            <Grid RowDefinitions="30,*"
                                                  RowSpacing="14">
                                                <TextBlock Classes="white"
                                                           FontSize="18"
                                                           TextAlignment="Center"
                                                           Text="SEEK" />
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Column="2"
                                              Width="154"
                                              Height="397"
                                              RowDefinitions="124,124"
                                              RowSpacing="12">
                                            <Border Grid.Row="0"
                                                    Classes="buttonFrame"
                                                    Width="154"
                                                    Height="124"
                                                    PointerPressed="OnAmFmChannelListPressed"
                                                    IsVisible="{Binding IsInternetChannelListButtonVisible}">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CH LIST" />
                                                </Viewbox>
                                            </Border>
                                            <Border Grid.Row="0"
                                                    Classes="panel"
                                                    Width="154"
                                                    Height="124"
                                                    IsVisible="{Binding !IsInternetChannelListButtonVisible}" />
                                            <Border Grid.Row="1" Classes="buttonFrame" Width="154" Height="124" PointerPressed="OnAmFmChannelSetPressed" IsVisible="{Binding !IsAmFmChannelSetArmed}">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CH&#x0a;SET" />
                                                </Viewbox>
                                            </Border>
                                            <Border Grid.Row="1" Classes="buttonFrame active" Width="154" Height="124" PointerPressed="OnAmFmChannelSetPressed" IsVisible="{Binding IsAmFmChannelSetArmed}">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CH&#x0a;SET" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Classes="panel"
                                Width="916"
                                Height="637"
                                IsVisible="{Binding IsCadContentVisible}"
                                Padding="24">
                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="16">
                                <TextBlock Classes="white"
                                           FontSize="32"
                                           Text="CAD" />
                                <TextBlock Grid.Row="1"
                                           Classes="white"
                                           FontSize="22"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Text="CAD tab content coming next." />
                            </Grid>
                        </Border>

                        <Border Classes="panel"
                                Width="916"
                                Height="637"
                                IsVisible="{Binding IsCameraContentVisible}"
                                Padding="24">
                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="16">
                                <TextBlock Classes="white"
                                           FontSize="32"
                                           Text="CAMERA" />
                                <TextBlock Grid.Row="1"
                                           Classes="white"
                                           FontSize="22"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Text="Camera tab content coming next." />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
            </Grid>
        </Viewbox>

        <Border IsVisible="{Binding IsAdminOverlayVisible}"
                Background="#F20B0B0B"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="2"
                Padding="16"
                ZIndex="100">
            <Grid ColumnDefinitions="320,*"
                  ColumnSpacing="16">
                <Border Classes="panel"
                        Grid.Column="0"
                        Padding="12">
                    <Grid RowDefinitions="Auto,*,Auto"
                          RowSpacing="12">
                        <TextBlock Classes="white"
                                   FontSize="26"
                                   Text="ADMIN" />

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10">
                                <Expander Classes="adminMenu" Header="SYSTEM" IsExpanded="True">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminSystemPressed" Padding="10">
                                            <TextBlock Classes="white" Text="General" />
                                        </Border>
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminSystemStatusPressed" Padding="10">
                                            <TextBlock Classes="white" Text="Status" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="AUDIO">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminAudioPressed" Padding="10">
                                            <TextBlock Classes="white" Text="Routing / Devices" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="RADIO">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminRadioPressed" Padding="10">
                                            <TextBlock Classes="white" Text="Resources / Channels" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="NETWORK">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminNetworkPressed" Padding="10">
                                            <TextBlock Classes="white" Text="MQTT / LAN" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="SECURITY">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminSecurityPressed" Padding="10">
                                            <TextBlock Classes="white" Text="Users / Roles" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="INTEGRATIONS">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminIntegrationsPressed" Padding="10">
                                            <TextBlock Classes="white" Text="Categories" />
                                        </Border>
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminIntegrationsWhat3WordsPressed" Padding="10">
                                            <TextBlock Classes="white" Text="what3words" />
                                        </Border>
                                    </StackPanel>
                                </Expander>

                                <Expander Classes="adminMenu" Header="DIAGNOSTICS">
                                    <StackPanel Spacing="8">
                                        <Border Classes="buttonFrame" PointerPressed="OnAdminDiagnosticsPressed" Padding="10">
                                            <TextBlock Classes="white" Text="Health / Logs" />
                                        </Border>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2"
                                Classes="buttonFrame"
                                PointerPressed="OnCloseAdminPressed"
                                Padding="12">
                            <TextBlock Classes="white"
                                       FontSize="18"
                                       TextAlignment="Center"
                                       Text="CLOSE ADMIN" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="panel"
                        Padding="20">
                    <Grid RowDefinitions="*">
                        <Border IsVisible="{Binding IsAdminPinPromptVisible}"
                                Classes="panel"
                                Padding="12"
                                MaxWidth="420"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
                                  RowSpacing="10">
                                <TextBlock Classes="white"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           Text="ADMIN ACCESS" />
                                <TextBlock Grid.Row="1"
                                           Classes="white"
                                           FontSize="14"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="Enter the admin PIN to unlock configuration pages." />
                                <Border Grid.Row="2"
                                        Classes="panel"
                                        Padding="10">
                                    <TextBlock Classes="white"
                                               FontSize="22"
                                               TextAlignment="Center"
                                               Text="{Binding AdminPinMaskedEntry}" />
                                </Border>
                                <TextBlock Grid.Row="3"
                                           Classes="white"
                                           FontSize="13"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="{Binding AdminPinStatus}" />
                                <Grid Grid.Row="4"
                                      ColumnDefinitions="Auto,Auto,Auto"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                        ColumnSpacing="6"
                                        RowSpacing="6"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Border Grid.Row="0" Grid.Column="0" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinDigitPressed" Tag="1">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="1" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinDigitPressed" Tag="2">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="2" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="2" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinDigitPressed" Tag="3">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="3" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="0" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinDigitPressed" Tag="4">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="4" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinDigitPressed" Tag="5">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="5" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="2" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinDigitPressed" Tag="6">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="6" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="0" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinDigitPressed" Tag="7">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="7" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="1" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinDigitPressed" Tag="8">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="8" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="2" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinDigitPressed" Tag="9">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="9" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="3" Grid.Column="0" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinClearPressed">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="CLR" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="3" Grid.Column="1" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinDigitPressed" Tag="0">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="0" /></Viewbox>
                                    </Border>
                                    <Border Grid.Row="3" Grid.Column="2" Classes="buttonFrame" Width="82" Height="60" PointerPressed="OnAdminPinBackspacePressed">
                                        <Viewbox Stretch="Uniform"><TextBlock Classes="white" Text="DEL" /></Viewbox>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid IsVisible="{Binding IsAdminContentVisible}"
                              RowDefinitions="Auto,Auto,*"
                              RowSpacing="10">
                            <TextBlock Classes="white"
                                       FontSize="26"
                                       Text="{Binding AdminSectionTitle}" />
                            <TextBlock Grid.Row="1"
                                       Classes="white"
                                        FontSize="15"
                                       TextWrapping="Wrap"
                                       Text="{Binding AdminSectionDescription}" />
                            <Border Grid.Row="2"
                                    Classes="panel"
                                    Padding="10"
                                    ClipToBounds="True">
                                <Grid RowDefinitions="*">
                                    <!-- Sections 3.9 and 6: this Axaml stays read-only and renders retained/admin reference data without becoming a source of truth. -->
                                    <ScrollViewer Grid.Row="0"
                                                  IsVisible="{Binding IsAdminSystemGeneralSectionSelected}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="10">
                                            <!-- Section 6: framework component reference cards generated from the shared view-model projection. -->
                                            <Border Classes="panel"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Classes="white"
                                                               FontSize="20"
                                                               Text="COMPONENT REFERENCE" />
                                                    <TextBlock Classes="white"
                                                               FontSize="14"
                                                               TextWrapping="Wrap"
                                                               Text="Framework-defined components and transport roles from PROJECT_FRAMEWORK section 6." />
                                                </StackPanel>
                                            </Border>

                                            <ItemsControl ItemsSource="{Binding AdminFrameworkComponentReferences}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="viewModels:AdminFrameworkComponentReference">
                                                        <Border Classes="buttonFrame"
                                                                Margin="0,0,0,8"
                                                                MaxWidth="540"
                                                                Padding="10">
                                                            <StackPanel Spacing="6">
                                                                <Grid ColumnDefinitions="*,Auto"
                                                                      ColumnSpacing="8">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="18"
                                                                                   Text="{Binding Name}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="12"
                                                                                   Text="{Binding Plane, StringFormat='PLANE: {0}'}" />
                                                                    </StackPanel>
                                                                    <Border Grid.Column="1"
                                                                            Background="#1E1E1E"
                                                                            BorderBrush="{StaticResource ActiveButtonBorderBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="2"
                                                                            Padding="6,3">
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="13"
                                                                                   Text="{Binding Status}" />
                                                                    </Border>
                                                                </Grid>
                                                                <TextBlock Classes="white"
                                                                           FontSize="14"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding Role}" />
                                                                <TextBlock Classes="white"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding TransportSummary, StringFormat='TRANSPORTS: {0}'}" />
                                                                <TextBlock Classes="white"
                                                                           FontSize="12"
                                                                           Text="{Binding IsCore, StringFormat='CORE: {0}'}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer Grid.Row="0"
                                                  IsVisible="{Binding IsAdminSystemStatusSectionSelected}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="10">
                                            <Border Classes="panel"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Classes="white"
                                                               FontSize="20"
                                                               Text="SYSTEM STATUS" />
                                                    <TextBlock Classes="white"
                                                               FontSize="14"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding AdminSystemStatusSummary}" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding MqttCommandFeedback}" />
                                                </StackPanel>
                                            </Border>

                                            <ItemsControl ItemsSource="{Binding SystemComponentStatuses}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="viewModels:AdminSystemComponentStatus">
                                                        <Border Classes="buttonFrame"
                                                                Margin="0,0,0,8"
                                                                MaxWidth="540"
                                                                Padding="10">
                                                            <StackPanel Spacing="6">
                                                                <Grid ColumnDefinitions="*,Auto"
                                                                      ColumnSpacing="8">
                                                                    <TextBlock Classes="white"
                                                                               FontSize="18"
                                                                               VerticalAlignment="Center"
                                                                               Text="{Binding DisplayName}" />
                                                                    <Border Grid.Column="1"
                                                                            Background="#1E1E1E"
                                                                            BorderBrush="{StaticResource ActiveButtonBorderBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="2"
                                                                            Padding="6,3">
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="14"
                                                                                   TextAlignment="Center"
                                                                                   Text="{Binding StatusLabel}" />
                                                                    </Border>
                                                                </Grid>
                                                                <TextBlock Classes="white"
                                                                           FontSize="14"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding Detail}" />
                                                                <TextBlock Classes="white"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding Topic}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer Grid.Row="0"
                                                  IsVisible="{Binding IsAdminAudioSectionSelected}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="8"
                                                    MaxWidth="560"
                                                    HorizontalAlignment="Stretch">
                                            <Border Classes="panel"
                                                    Padding="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Classes="white"
                                                               FontSize="18"
                                                               Text="MASTER MIXER OUTPUT" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="Select the AP master output device. All other AP audio devices remain channel endpoints." />
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="buttonFrame"
                                                    Padding="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding AdminAudioStatus}" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               Text="{Binding AppliedAudioOutputSpeakerLabel, StringFormat='APPLIED: {0}'}" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               Text="{Binding SelectedAudioOutputSpeakerLabel, StringFormat='SELECTED: {0}'}" />
                                                    <TextBlock Classes="white"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding AdminAudioDeviceSummary}" />
                                                </StackPanel>
                                            </Border>

                                            <ScrollViewer MaxHeight="156"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding AudioOutputDevices}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:AudioDeviceStateMessage">
                                                        <Border Classes="buttonFrame"
                                                                Margin="0,0,0,8"
                                                            Padding="8"
                                                                Tag="{Binding DeviceId}"
                                                                PointerPressed="OnAdminAudioOutputSpeakerPressed">
                                                            <Grid ColumnDefinitions="*,Auto"
                                                                ColumnSpacing="6">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Classes="white"
                                                                                FontSize="15"
                                                                               Text="{Binding DisplayName}" />
                                                                    <TextBlock Classes="white"
                                                                                FontSize="10"
                                                                               Text="{Binding DeviceId}" />
                                                                </StackPanel>
                                                                <Border Grid.Column="1"
                                                                        Background="#1E1E1E"
                                                                        BorderBrush="{StaticResource ActiveButtonBorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="2"
                                                                        Padding="5,2"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Classes="white"
                                                                                FontSize="11"
                                                                               Text="SELECT" />
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <Border Classes="buttonFrame"
                                                    IsVisible="{Binding HasAudioOutputDevices}"
                                                    PointerPressed="OnAdminPushAudioConfigPressed"
                                                    Padding="8">
                                                <TextBlock Classes="white"
                                                           FontSize="15"
                                                           TextAlignment="Center"
                                                           Text="PUSH CONFIG TO AP" />
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer Grid.Row="0"
                                                  IsVisible="{Binding IsAdminRadioSectionSelected}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="8"
                                                    MaxWidth="560"
                                                    HorizontalAlignment="Stretch">
                                            <!-- Sections 4.1, 4.3, and 6: show retained type availability separately from declared/runtime radios so built-in resource radios can be added without RMs. -->
                                            <Border Classes="panel"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Classes="white"
                                                               FontSize="18"
                                                               Text="ADDABLE RADIO TYPES" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding AdminAvailableRadioTypeSummary}" />
                                                    <TextBlock Classes="white"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               IsVisible="{Binding HasAvailableRadioTypes}"
                                                               Text="Built-in AP radio resources appear here even when no RM plugins are loaded. VOX/resource radios do not require an RM." />
                                                </StackPanel>
                                            </Border>

                                            <ItemsControl ItemsSource="{Binding AvailableRadioTypes}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:RadioRegistryEntryMessage">
                                                        <Border Classes="buttonFrame"
                                                                MaxWidth="560"
                                                                Margin="0,0,0,8"
                                                                Padding="10">
                                                            <StackPanel Spacing="6">
                                                                <Grid ColumnDefinitions="*,Auto"
                                                                      ColumnSpacing="8">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="16"
                                                                                   Text="{Binding DisplayName}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   TextWrapping="Wrap"
                                                                                   Text="{Binding TypeId, StringFormat='TYPE: {0}'}" />
                                                                    </StackPanel>
                                                                    <Border Grid.Column="1"
                                                                            Background="#1E1E1E"
                                                                            BorderBrush="{StaticResource ActiveButtonBorderBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="2"
                                                                            Padding="6,3"
                                                                            VerticalAlignment="Top">
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="12"
                                                                                   Text="{Binding Kind}" />
                                                                    </Border>
                                                                </Grid>
                                                                <TextBlock Classes="white"
                                                                           FontSize="11"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding Capabilities.Keying.Count, StringFormat='KEYING OPTIONS: {0}'}" />
                                                                <TextBlock Classes="white"
                                                                           FontSize="11"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding Capabilities.Detect.Count, StringFormat='DETECT OPTIONS: {0}'}" />
                                                                <TextBlock Classes="white"
                                                                           FontSize="11"
                                                                           TextWrapping="Wrap"
                                                                           Text="Tap-to-add is the next Radio admin step; this list confirms the AP sees the type and that built-in resources are available without plugins." />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Border Classes="panel"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Classes="white"
                                                               FontSize="18"
                                                               Text="RADIO RUNTIME" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding AdminRadioSummary}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="panel"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Classes="white"
                                                               FontSize="18"
                                                               Text="SCHEMA-DRIVEN ADMIN" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding AdminSchemaSummary}" />
                                                    <ItemsControl ItemsSource="{Binding AdminSchemaModules}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="viewModels:AdminSchemaModuleProjection">
                                                                <Border Classes="buttonFrame"
                                                                        Margin="0,0,0,8"
                                                                        Padding="8">
                                                                    <StackPanel Spacing="4">
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="15"
                                                                                   Text="{Binding Id}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding TypeId, StringFormat='TYPE: {0}'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding FieldPaths.Count, StringFormat='SCHEMA FIELDS: {0}'}" />
                                                                        <ItemsControl ItemsSource="{Binding FieldPaths}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBlock Classes="white"
                                                                                               FontSize="10"
                                                                                               Text="{Binding .}" />
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <ItemsControl ItemsSource="{Binding RadioRuntimeEntries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:RadioRuntimeEntryMessage">
                                                        <Border Classes="buttonFrame"
                                                                MaxWidth="560"
                                                                Margin="0,0,0,8"
                                                                Padding="10">
                                                            <StackPanel Spacing="8">
                                                                <Grid ColumnDefinitions="*,Auto"
                                                                      ColumnSpacing="8">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="18"
                                                                                   Text="{Binding DisplayName}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   TextWrapping="Wrap"
                                                                                   Text="{Binding RadioId, StringFormat='ID: {0}'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   TextWrapping="Wrap"
                                                                                   Text="{Binding TypeId, StringFormat='TYPE: {0}'}" />
                                                                    </StackPanel>
                                                                    <Border Grid.Column="1"
                                                                            Background="#1E1E1E"
                                                                            BorderBrush="{StaticResource ActiveButtonBorderBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="2"
                                                                            Padding="6,3"
                                                                            VerticalAlignment="Top">
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="13"
                                                                                   Text="{Binding Kind}" />
                                                                    </Border>
                                                                </Grid>

                                                                <Grid ColumnDefinitions="*,*"
                                                                      ColumnSpacing="8">
                                                                    <Border Classes="panel"
                                                                            Padding="8">
                                                                        <StackPanel Spacing="4">
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="14"
                                                                                       Text="CAPABILITIES" />
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="{Binding Capabilities.Keying.Count, StringFormat='KEYING MODES: {0}'}" />
                                                                            <ItemsControl ItemsSource="{Binding Capabilities.Keying}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <TextBlock Classes="white"
                                                                                                   FontSize="11"
                                                                                                   Text="{Binding .}" />
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="{Binding Capabilities.Detect.Count, StringFormat='DETECT MODES: {0}'}" />
                                                                            <ItemsControl ItemsSource="{Binding Capabilities.Detect}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <TextBlock Classes="white"
                                                                                                   FontSize="11"
                                                                                                   Text="{Binding .}" />
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       Text="{Binding Capabilities.ProvidesAudio, StringFormat='AUDIO: {0}'}" />
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="{Binding Capabilities.Controls.Count, StringFormat='CONTROLS: {0}'}" />
                                                                            <ItemsControl ItemsSource="{Binding Capabilities.Controls}">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <TextBlock Classes="white"
                                                                                                   FontSize="11"
                                                                                                   Text="{Binding .}" />
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>
                                                                    </Border>

                                                                    <Border Grid.Column="1"
                                                                            Classes="panel"
                                                                            Padding="8">
                                                                        <StackPanel Spacing="4">
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="14"
                                                                                       Text="TX STATE" />
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       Text="{Binding TxState.Phase, StringFormat='PHASE: {0}'}" />
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       Text="{Binding TxState.KeyingMethod, StringFormat='KEYING: {0}'}" />
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       Text="{Binding TxState.IsKeyAsserted, StringFormat='KEY ASSERTED: {0}'}" />
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       Text="{Binding TxState.IsTalkPermitReady, StringFormat='TALK PERMIT: {0}'}" />
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       Text="{Binding TxState.PttLeadMs, StringFormat='PTT LEAD: {0} ms'}" />
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       Text="{Binding TxState.PttTailMs, StringFormat='PTT TAIL: {0} ms'}" />
                                                                            <TextBlock Classes="white"
                                                                                       FontSize="11"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="{Binding TxState.LastTransitionUtc, StringFormat='LAST CHANGE: {0:yyyy-MM-dd HH:mm:ss} UTC'}" />
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>

                                                                <Border Classes="panel"
                                                                        Padding="8">
                                                                    <StackPanel Spacing="4">
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="14"
                                                                                   Text="INSTANCE CONFIG" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Keying.Method, StringFormat='PTT METHOD: {0}'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Keying.PttLeadMs, StringFormat='CONFIG LEAD: {0} ms'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Keying.PttTailMs, StringFormat='CONFIG TAIL: {0} ms'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Keying.TalkPermit, StringFormat='CONFIG TALK PERMIT: {0}'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Detect.Method, StringFormat='DETECT METHOD: {0}'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Device.Soundcard, StringFormat='SOUNDCARD: {0}'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Keying.Relay.RelaySet, StringFormat='RELAY SET: {0}'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Keying.Relay.Channel, StringFormat='RELAY CHANNEL: {0}'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Detect.Vox.ThresholdDb, StringFormat='VOX THRESHOLD: {0} dB'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Detect.Vox.AttackMs, StringFormat='VOX ATTACK: {0} ms'}" />
                                                                        <TextBlock Classes="white"
                                                                                   FontSize="11"
                                                                                   Text="{Binding Config.Detect.Vox.HangMs, StringFormat='VOX HANG: {0} ms'}" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer Grid.Row="0"
                                                  IsVisible="{Binding IsAdminNetworkSectionSelected}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="8"
                                                    MaxWidth="620"
                                                    HorizontalAlignment="Stretch">
                                            <Border Classes="panel"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Classes="white"
                                                               FontSize="18"
                                                               Text="NETWORK" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="MQTT broker, LAN addressing, and remote endpoint settings will render here." />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer Grid.Row="0"
                                                  IsVisible="{Binding IsAdminIntegrationsSectionSelected}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="8"
                                                    MaxWidth="620"
                                                    HorizontalAlignment="Stretch">
                                            <Border Classes="panel"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Classes="white"
                                                               FontSize="18"
                                                               Text="INTEGRATION CATEGORIES" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="Select an external integration category from the admin menu to configure its settings." />
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="buttonFrame"
                                                    PointerPressed="OnAdminIntegrationsWhat3WordsPressed"
                                                    Padding="10">
                                                <TextBlock Classes="white"
                                                           FontSize="15"
                                                           TextAlignment="Center"
                                                           Text="OPEN WHAT3WORDS SETTINGS" />
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <ScrollViewer Grid.Row="0"
                                                  IsVisible="{Binding IsAdminIntegrationsWhat3WordsSectionSelected}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="8"
                                                    MaxWidth="620"
                                                    HorizontalAlignment="Stretch">
                                            <Border Classes="panel"
                                                    Padding="10">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Classes="white"
                                                               FontSize="18"
                                                               Text="WHAT3WORDS API" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="Save the what3words API key used to convert the current GPS location into a three-word dashboard label." />
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="buttonFrame"
                                                    Padding="10">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               Text="API KEY" />
                                                    <TextBox Text="{Binding AdminWhat3WordsApiKey}"
                                                             Watermark="Enter what3words API key"
                                                             FontSize="14"
                                                             MinWidth="320" />
                                                    <TextBlock Classes="white"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               Text="{Binding AdminWhat3WordsStatus}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="buttonFrame"
                                                    PointerPressed="OnAdminSaveWhat3WordsApiKeyPressed"
                                                    Padding="10">
                                                <TextBlock Classes="white"
                                                           FontSize="15"
                                                           TextAlignment="Center"
                                                           Text="SAVE WHAT3WORDS KEY" />
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <TextBlock Grid.Row="1"
                                               IsVisible="{Binding IsAdminNonSystemSectionSelected}"
                                               Classes="white"
                                               FontSize="18"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Text="Configuration editor placeholder. The selected admin category will render here full screen." />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsInternetChannelListVisible}"
                Background="#E6101010"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="2"
                Padding="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="620"
                Width="620"
                ZIndex="90">
            <Grid RowDefinitions="Auto,Auto,*,Auto"
                  RowSpacing="10">
                <TextBlock Classes="white"
                           FontSize="20"
                           Text="INT CHANNEL LIST" />

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*,Auto"
                      ColumnSpacing="8">
                    <Border Grid.Column="0"
                            Classes="buttonFrame"
                            PointerPressed="OnInternetGenreFilterPressed"
                            Padding="8">
                        <TextBlock Classes="white"
                                   Text="{Binding InternetGenreFilter, StringFormat='GENRE: {0}'}" />
                    </Border>
                    <Border Grid.Column="1"
                            Classes="buttonFrame"
                            PointerPressed="OnInternetLanguageFilterPressed"
                            Padding="8">
                        <TextBlock Classes="white"
                                   Text="{Binding InternetLanguageFilter, StringFormat='LANG: {0}'}" />
                    </Border>
                    <Border Grid.Column="2"
                            Classes="buttonFrame"
                            PointerPressed="OnCloseInternetChannelListPressed"
                            Padding="8,8,12,8">
                        <TextBlock Classes="white"
                                   Text="CLOSE" />
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      RowDefinitions="Auto,*,Auto"
                      RowSpacing="8">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                        <Border Classes="buttonFrame"
                                Width="72"
                                Height="52"
                                PointerPressed="OnInternetStationsUpPressed"
                                IsEnabled="{Binding CanScrollInternetStationsUp}">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="▲" />
                            </Viewbox>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Classes="white"
                                   VerticalAlignment="Center"
                                   Text="Touch-friendly paging for Internet radio channels." />
                    </Grid>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding VisibleInternetRadioStations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:InternetRadioStation">
                                <Border Classes="buttonFrame"
                                        Margin="0,0,0,8"
                                        Padding="10"
                                        PointerPressed="OnInternetStationPressed"
                                        Tag="{Binding StreamUrl}">
                                    <Grid ColumnDefinitions="2*,*,Auto"
                                          ColumnSpacing="10">
                                        <TextBlock Classes="white"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding DisplayName}" />
                                        <TextBlock Grid.Column="1"
                                                   Classes="white"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Genre}" />
                                        <TextBlock Grid.Column="2"
                                                   Classes="white"
                                                   Text="{Binding Language}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="2"
                            Classes="buttonFrame"
                            Width="72"
                            Height="52"
                            HorizontalAlignment="Left"
                            PointerPressed="OnInternetStationsDownPressed"
                            IsEnabled="{Binding CanScrollInternetStationsDown}">
                        <Viewbox Stretch="Uniform">
                            <TextBlock Classes="white"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="▼" />
                        </Viewbox>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="3"
                           Classes="white"
                           FontSize="14"
                           Text="Select A Station" />
            </Grid>
        </Border>
    </Grid>
</Window>