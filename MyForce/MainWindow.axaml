<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="using:MyForce.ViewModels"
        x:Class="MyForce.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        mc:Ignorable="d"
        d:DesignWidth="1366"
        d:DesignHeight="768"
        WindowState="FullScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="#2D090B"
        Title="MyForce">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush" Color="#2D090B" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#6A0D14" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8F8F8" />
        <SolidColorBrush x:Key="SignalBrush" Color="#9BD653" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#808080" />
        <SolidColorBrush x:Key="ActiveButtonBorderBrush" Color="#7DB4F0" />
        <SolidColorBrush x:Key="ActiveButtonBrush" Color="#2B71BB" />
        <SolidColorBrush x:Key="AlertBrush" Color="#96302A" />

        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#191919" Offset="0" />
            <GradientStop Color="#101010" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#3A3A3A" Offset="0" />
            <GradientStop Color="#232323" Offset="0.45" />
            <GradientStop Color="#111111" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>

        <Style Selector="Border.buttonFrame">
            <Setter Property="Background" Value="{StaticResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>

        <Style Selector="Border.buttonFrame.active">
            <Setter Property="Background" Value="{StaticResource ActiveButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ActiveButtonBorderBrush}" />
        </Style>

        <Style Selector="TextBlock.white">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Styles>

    <Grid Background="{StaticResource ShellBrush}">
        <Viewbox Stretch="Fill"
                 StretchDirection="DownOnly">
            <Grid Width="1280"
                  Height="760"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="0"
                  ColumnDefinitions="304,948"
                  ColumnSpacing="10">
            <Grid Grid.Column="0"
                  Width="304"
                  Height="748"
                  RowDefinitions="87,180,116,101,120,88"
                  RowSpacing="10">
                <Border Grid.Row="0" Classes="panel" Width="304" Height="87" Padding="8">
                    <Grid ColumnDefinitions="89,176" ColumnSpacing="9" HorizontalAlignment="Center">
                        <StackPanel Width="89" Height="63" Spacing="0" HorizontalAlignment="Center">
                            <TextBlock Classes="white"
                                       Width="89"
                                       Height="24"
                                       FontSize="18"
                                       TextAlignment="Center"
                                       Text="{Binding SpeedLabel}" />
                            <TextBlock Width="89"
                                       Height="42"
                                       Foreground="{StaticResource SignalBrush}"
                                       FontFamily="Segoe UI"
                                       FontWeight="Bold"
                                       FontSize="30"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding SpeedValue}" />
                            
                        </StackPanel>

                        <StackPanel Grid.Column="1" Width="176" Height="63" Spacing="0" HorizontalAlignment="Center">
                            <TextBlock Classes="white"
                                       Width="176"
                                       Height="24"
                                       FontSize="18"
                                       TextAlignment="Center"
                                       Text="{Binding LocationLabel}" />
                            <TextBlock Width="176"
                                       Height="42"
                                       Foreground="{StaticResource SignalBrush}"
                                       FontFamily="Segoe UI"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{Binding LocationValue}" />

                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Classes="panel" Width="304" Height="180" Padding="12">
                    <Grid RowDefinitions="35,29,87" RowSpacing="0">
                        <TextBlock Classes="white"
                                   Height="35"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Text="{Binding TalkRadio}" />
                        <TextBlock Grid.Row="1"
                                   Classes="white"
                                   Height="29"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   Text="{Binding RadioChannel}" />
                        <Grid Grid.Row="2"
                              Width="278"
                              Height="87"
                              ColumnDefinitions="86,86,88"
                              ColumnSpacing="6"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Bottom">
                            <Border Grid.Column="0" Classes="buttonFrame" Width="86" Height="81">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="CH UP" />
                                </Viewbox>
                            </Border>
                            <Border Grid.Column="1" Classes="buttonFrame" Width="86" Height="81">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="CH DN" />
                                </Viewbox>
                            </Border>
                            <Border Grid.Column="2" Classes="buttonFrame" Width="88" Height="81">
                                <Viewbox Stretch="Uniform">
                                    <TextBlock Classes="white"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="SCAN" />
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Classes="panel" Width="304" Height="126" Padding="12">
                    <TextBlock Classes="white"
                               Width="278"
                               Height="125"
                               FontSize="18"
                               TextWrapping="Wrap"
                               Text="{Binding AlertStatus}" />
                </Border>

                <Border Grid.Row="3" Classes="panel" Width="304" Height="100" Padding="12,10">
                    <TextBlock Classes="white"
                               Width="278"
                               Height="43"
                               FontSize="13"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               Text="{Binding CadMessage}" />
                </Border>

                <Border Grid.Row="4" Classes="panel" Width="304" Height="130" Padding="12">
                    <Grid Width="278"
                          Height="99"
                          ColumnDefinitions="86,86,88"
                          ColumnSpacing="6"
                          VerticalAlignment="Bottom">
                        <Border Grid.Column="0" Classes="buttonFrame" Width="86" Height="93">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="REC" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="1" Classes="buttonFrame" Width="86" Height="93">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="STOP" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="2" Classes="buttonFrame" Width="88" Height="93">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="AUTOZ" />
                            </Viewbox>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="5" Classes="panel" Width="298" Height="88" Padding="8">
                    <Grid Width="280"
                          Height="70"
                          ColumnDefinitions="128,65,69"
                          ColumnSpacing="6">
                        <StackPanel Width="128" Height="64" Spacing="0">
                            <TextBlock Classes="white"
                                       Width="128"
                                       Height="34"
                                       FontSize="28"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Text="{Binding Clock}" />
                            <TextBlock Classes="white"
                                       Width="128"
                                       Height="23"
                                       FontSize="15"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Padding="8,0"
                                       Text="{Binding Date}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Width="65" Height="64" Spacing="0">
                            <TextBlock Classes="white"
                                       Width="65"
                                       Height="26"
                                       FontSize="20"
                                       TextAlignment="Center"
                                       Text="VOL" />
                            <TextBlock Width="65"
                                       Height="37"
                                       Foreground="{StaticResource SignalBrush}"
                                       FontFamily="Segoe UI"
                                       FontWeight="Bold"
                                       FontSize="28"
                                       TextAlignment="Center"
                                       Text="{Binding Volume}" />
                        </StackPanel>

                        <Border Grid.Column="2"
                                Width="69"
                                Height="64"
                                Background="{StaticResource AlertBrush}"
                                BorderBrush="{StaticResource ActiveButtonBorderBrush}"
                                BorderThickness="2"
                                CornerRadius="3"
                                PointerPressed="OnEmergencyExitPressed">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="E-911" />
                            </Viewbox>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1"
                    Width="948"
                    Height="742"
                    Background="#000000"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="2"
                    CornerRadius="2"
                    Padding="8">
                <Grid Width="930"
                      Height="724"
                      RowDefinitions="66,637"
                      RowSpacing="9">
                    <Grid Width="924"
                          Height="66"
                          ColumnDefinitions="125,125,125,125,125,125,131"
                          ColumnSpacing="6">
                        <Border Grid.Column="0" Classes="buttonFrame active" Width="125" Height="58" VerticalAlignment="Top">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="PATROL" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="1" Classes="buttonFrame" Width="125" Height="58" VerticalAlignment="Top">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="L / S" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="2" Classes="buttonFrame" Width="125" Height="58" VerticalAlignment="Top">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="RADIO" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="3" Classes="buttonFrame" Width="125" Height="58" VerticalAlignment="Top">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="RADAR" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="4" Classes="buttonFrame" Width="125" Height="58" VerticalAlignment="Top">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="AM/FM" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="5" Classes="buttonFrame" Width="125" VerticalAlignment="Top">
                            <Viewbox Width="125" Height="53" Stretch="Uniform">
                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CAD" />
                            </Viewbox>
                        </Border>
                        <Border Grid.Column="6" Classes="buttonFrame" Width="131" Height="58" VerticalAlignment="Top">
                            <Viewbox Stretch="Uniform">
                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="CAMERA" />
                            </Viewbox>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          Width="916"
                          Height="637"
                          ColumnDefinitions="322,578"
                          ColumnSpacing="10">
                        <Border Grid.Column="0" Classes="panel" Width="322" Height="637" Padding="8">
                            <Grid Width="304"
                                  Height="619"
                                  RowDefinitions="223,238,132"
                                  RowSpacing="10">
                                <Border Grid.Row="0" Classes="panel" Width="304" Height="223" Padding="10">
                                    <StackPanel Width="282" Height="204" Spacing="0">
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="RADIO 1: CT OPS 800" />
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="RADIO 2: CT OPS V" />
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="RADIO 3: TXT MAIN" />
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="RADIO 4: CT ALE M" />
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="RADIO 5: $CMD_1" />
                                        <TextBlock Classes="white" Width="282" Height="34" FontSize="18" Text="RADIO 6: ABIA TWR" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Classes="panel" Width="304" Height="238" Padding="10">
                                    <Grid Width="282" Height="216" RowDefinitions="32,184" RowSpacing="0">
                                        <TextBlock Classes="white"
                                                   Width="282"
                                                   Height="32"
                                                   FontSize="18"
                                                   TextAlignment="Center"
                                                   Text="PROXIMITY LIST" />
                                        <Grid Grid.Row="1"
                                              Width="282"
                                              Height="184"
                                              ColumnDefinitions="135,135"
                                              RowDefinitions="86,86"
                                              ColumnSpacing="6"
                                              RowSpacing="6">
                                            <Border Grid.Row="0" Grid.Column="0" Classes="buttonFrame" Width="135" Height="86">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="CT OPS 800" />
                                                </Viewbox>
                                            </Border>
                                            <Border Grid.Row="0" Grid.Column="1" Classes="buttonFrame" Width="135" Height="86">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="DFW TAC1" />
                                                </Viewbox>
                                            </Border>
                                            <Border Grid.Row="1" Grid.Column="0" Classes="buttonFrame" Width="135" Height="86">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="$CMD_1" />
                                                </Viewbox>
                                            </Border>
                                            <Border Grid.Row="1" Grid.Column="1" Classes="buttonFrame" Width="135" Height="86">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="DFW_TWR_E" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Classes="panel" Width="298" Height="132" Padding="10">
                                    <Grid Width="276" Height="110" RowDefinitions="32,78">
                                        <TextBlock Classes="white"
                                                   Width="276"
                                                   Height="32"
                                                   FontSize="18"
                                                   TextAlignment="Center"
                                                   Text="VOLUME" />
                                        <Grid Grid.Row="1"
                                              Width="276"
                                              Height="78"
                                              ColumnDefinitions="132,132"
                                              ColumnSpacing="6">
                                            <Border Grid.Column="0" Classes="buttonFrame" Width="132" Height="72">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▲" />
                                                </Viewbox>
                                            </Border>
                                            <Border Grid.Column="1" Classes="buttonFrame" Width="132" Height="72">
                                                <Viewbox Stretch="Uniform">
                                                    <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▼" />
                                                </Viewbox>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1"
                              Width="578"
                              Height="631"
                              RowDefinitions="116,114,375"
                              RowSpacing="10">
                            <Border Grid.Row="0" Classes="panel" Width="578" Height="116" Padding="8">
                                <Grid Width="560"
                                      Height="98"
                                      ColumnDefinitions="180,180,182"
                                      ColumnSpacing="6">
                                    <Grid Grid.Column="0" Width="180" Height="92" RowDefinitions="28,64">
                                        <TextBlock Classes="white" Width="180" Height="28" FontSize="18" TextAlignment="Center" Text="CODE 1" />
                                        <Border Grid.Row="1" Classes="buttonFrame active" Width="180" Height="64">
                                            <Viewbox Stretch="Fill">
                                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1" Text="ON" />
                                            </Viewbox>
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Column="1" Width="180" Height="92" RowDefinitions="28,64">
                                        <TextBlock Classes="white" Width="180" Height="28" FontSize="18" TextAlignment="Center" Text="CODE 2" />
                                        <Border Grid.Row="1" Classes="buttonFrame" Width="180" Height="64">
                                            <Viewbox Stretch="Fill">
                                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1"  Text="OFF" />
                                            </Viewbox>
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Column="2" Width="182" Height="92" RowDefinitions="28,64">
                                        <TextBlock Classes="white" Width="182" Height="28" FontSize="18" TextAlignment="Center" Text="CODE 3" />
                                        <Border Grid.Row="1" Classes="buttonFrame" Width="182" Height="64">
                                            <Viewbox Stretch="Fill">
                                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" FontSize="1"  Text="OFF" />
                                            </Viewbox>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Classes="panel" Width="578" Height="114" Padding="8">
                                <Grid Width="560" Height="96" RowDefinitions="32,64">
                                    <TextBlock Classes="white"
                                               Width="560"
                                               Height="32"
                                               FontSize="18"
                                               TextAlignment="Center"
                                               Text="DIRECTIONALS" />
                                    <Grid Grid.Row="1"
                                          Width="560"
                                          Height="64"
                                          ColumnDefinitions="180,180,182"
                                          ColumnSpacing="6">
                                        <Border Grid.Column="0" Classes="buttonFrame" Width="180" Height="58">
                                            <Viewbox Stretch="Uniform">
                                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="◀" />
                                            </Viewbox>
                                        </Border>
                                        <Border Grid.Column="1" Classes="buttonFrame" Width="180" Height="58">
                                            <Viewbox Stretch="Uniform">
                                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="◀▶" />
                                            </Viewbox>
                                        </Border>
                                        <Border Grid.Column="2" Classes="buttonFrame active" Width="182" Height="58">
                                            <Viewbox Stretch="Uniform">
                                                <TextBlock Classes="white" TextAlignment="Center" VerticalAlignment="Center" Text="▶" />
                                            </Viewbox>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2"
                                  Width="572"
                                  Height="375"
                                  ColumnDefinitions="183,183,186"
                                  ColumnSpacing="8">
                                <Grid Grid.Column="0" Width="183" Height="369" RowDefinitions="176,185" RowSpacing="8" VerticalAlignment="Top">
                                    <Border Grid.Row="0" Classes="panel" Width="175" Height="176" Padding="8">
                                        <Grid Width="157" Height="158" RowDefinitions="28,130">
                                            <TextBlock Classes="white"
                                                       Width="157"
                                                       Height="28"
                                                       FontSize="20"
                                                       TextAlignment="Center"
                                                       Text="L / S" />
                                            <Border Grid.Row="1" Classes="buttonFrame" Width="157" Height="130">
                                                <Grid>
                                                    <Viewbox Stretch="Uniform"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             MaxWidth="130"
                                                             MaxHeight="104">
                                                        <TextBlock Classes="white"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Text="L / S&#x0a;OFF" />
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1" Classes="panel" Width="175" Height="185" Padding="8">
                                        <Grid Width="157" Height="167" RowDefinitions="28,139">
                                            <TextBlock Classes="white"
                                                       Width="157"
                                                       Height="28"
                                                       FontSize="13.333"
                                                       TextAlignment="Center"
                                                       Text="EXT AUDIO" />
                                            <Border Grid.Row="1" Classes="buttonFrame" Width="157" Height="139">
                                                <Grid>
                                                    <Viewbox Stretch="Uniform"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             MaxWidth="120"
                                                             MaxHeight="110">
                                                        <TextBlock Classes="white"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Text="OFF" />
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Border Grid.Column="1" Classes="panel" Width="183" Height="179" Padding="8" VerticalAlignment="Top">
                                    <Grid Width="165" Height="161" RowDefinitions="28,133">
                                        <TextBlock Classes="white"
                                                   Width="165"
                                                   Height="28"
                                                   FontSize="18"
                                                   TextAlignment="Center"
                                                   Text="MEMO" />
                                        <Border Grid.Row="1" Classes="buttonFrame" Width="165" Height="133">
                                            <Grid>
                                                <Viewbox Stretch="Uniform"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         MaxWidth="120"
                                                         MaxHeight="90">
                                                    <TextBlock Classes="white"
                                                               TextAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="REC" />
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Classes="panel" Width="186" Height="176" Padding="8" VerticalAlignment="Top">
                                    <Grid Width="168" Height="158" RowDefinitions="28,130">
                                        <TextBlock Classes="white"
                                                   Width="168"
                                                   Height="28"
                                                   FontSize="18"
                                                   TextAlignment="Center"
                                                   Text="AM / FM" />
                                        <Border Grid.Row="1" Classes="buttonFrame" Width="168" Height="130">
                                            <Grid>
                                                <Viewbox Stretch="Uniform"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         MaxWidth="128"
                                                         MaxHeight="92">
                                                    <TextBlock Classes="white"
                                                               TextAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="MUTE" />
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
            </Grid>
        </Viewbox>
    </Grid>
</Window>